# YouTube Data API v3 key
# Google Cloud Console → APIs & Services → Credentials → Create API Key
# Enable "YouTube Data API v3" on the key.
YOUTUBE_API_KEY=

# Path to a Google service account JSON credential file.
# Cloud Console → IAM → Service Accounts → Create → Download JSON key.
# Enable "Google Drive API" and "Google Sheets API" for the project.
# Share the target Drive folder (or "My Drive") with the service account email.
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service-account.json

# Anthropic API key — only needed when running with --with-pitches.
ANTHROPIC_API_KEY=

# Optional: Google Drive folder ID to create "Tournamental GTM" inside.
# Leave blank to use Drive root.
# Get the ID from the folder URL: drive.google.com/drive/folders/<ID>
GOOGLE_DRIVE_PARENT_FOLDER_ID=
