# VTourn dev environment template.
# Copy to .env and fill in real values. .env is gitignored.

# --- Application ---
NODE_ENV=development
LOG_LEVEL=info

# --- Database (Postgres 16, dockerised, port 5435) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_DB=vtorn
POSTGRES_USER=vtorn
POSTGRES_PASSWORD=replace-with-a-real-password
DATABASE_URL=postgres://vtorn:replace-with-a-real-password@localhost:5435/vtorn?schema=public

# --- Cache (Redis 7, dockerised, port 6380) ---
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=replace-with-a-real-password
REDIS_URL=redis://:replace-with-a-real-password@localhost:6380

# --- Backups ---
VTORN_BACKUP_DIR=/var/backups/vtorn
# If set, weekly archives are mirrored here (e.g. an rclone-mounted R2/S3 path).
# VTORN_BACKUP_OFFSITE_DIR=/mnt/r2/vtorn-backups

# --- Restore safety ---
# Comma-separated hosts where db-restore.sh is allowed to run without force.
VTORN_RESTORE_ALLOW_HOSTS=localhost,127.0.0.1
# Set to 1 to apply infra/db/pii-scrub.sql after restoring a prod snapshot
# into a lower environment. Default 0.
VTORN_RESTORE_PII_SCRUB=0

# --- Service ports (informational; bound by the services themselves) ---
# Renderer (apps/web) Next.js dev:        3300
# Producer WS (apps/statsbomb-replay):    4001
# Producer WS (apps/mock-producer):       4001 (one at a time)
# API (apps/api):                         3310
# Marketing (apps/marketing, future):     3320

# --- API ---
VTORN_API_PORT=3310
VTORN_API_BIND=0.0.0.0
VTORN_API_CORS_ORIGINS=https://vtorn.aiva.nz,http://localhost:3300

# --- Renderer ---
NEXT_PUBLIC_STREAM_URL=ws://localhost:4001
NEXT_PUBLIC_API_URL=https://vtorn-api.aiva.nz
NEXT_PUBLIC_AUTH_API_URL=http://localhost:3330

# --- Auth service (apps/auth-sms) — see docs/32-auth-and-privacy.md ---
AUTH_PORT=3330
AUTH_BIND=0.0.0.0
AUTH_APP_HOST=vtourn.com
AUTH_PRODUCT_NAME=VTourn
AUTH_DB_PATH=./apps/auth-sms/data/auth.db
# 32+ char secrets — generate with: openssl rand -hex 32
# (leave blank in .env.example; set real values in .env, never committed)
AUTH_OTP_SECRET=
AUTH_JWT_SECRET=
AUTH_ADMIN_TOKEN=
AUTH_OTP_TTL_SECONDS=600
AUTH_MAX_VERIFY_ATTEMPTS=5
AUTH_SESSION_TTL_SECONDS=2592000

# Aiva SMS gateway (sms.aiva.nz). See clawdia/skills/aiva-sms/SKILL.md.
AIVA_SMS_API_URL=http://localhost:9252
AIVA_SMS_API_KEY=
AIVA_SMS_DEVICE_ID=
# WhatsApp transport: "aiva" (default) or "baileys" (in-process).
WHATSAPP_TRANSPORT=aiva
AIVA_WA_SESSION_ID=
# Only used when WHATSAPP_TRANSPORT=baileys.
BAILEYS_AUTH_DIR=./apps/auth-sms/baileys-auth
BAILEYS_QR_PATH=./apps/auth-sms/baileys-auth/last-qr.png

# --- Phase-3 commentary (ElevenLabs realtime TTS) ---
# When ELEVENLABS_API_KEY is unset, /api/commentary/sign returns a stub
# response (signed: false) and the renderer mounts a silent buffer so
# the audio mixer + ducking pipeline can still be tested end-to-end.
# Drop a real key here to enable live WSS commentary.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID_EN=
# ELEVENLABS_VOICE_ID_ES=
# ELEVENLABS_MODEL=eleven_turbo_v2_5
