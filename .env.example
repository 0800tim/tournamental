# Tournamental dev environment template.
# Copy to .env and fill in real values. .env is gitignored.

# --- Application ---
NODE_ENV=development
LOG_LEVEL=info

# --- Database (Postgres 16, dockerised, port 5435) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_DB=vtorn
POSTGRES_USER=vtorn
POSTGRES_PASSWORD=replace-with-a-real-password
DATABASE_URL=postgres://vtorn:replace-with-a-real-password@localhost:5435/vtorn?schema=public

# --- Cache (Redis 7, dockerised, port 6380) ---
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=replace-with-a-real-password
REDIS_URL=redis://:replace-with-a-real-password@localhost:6380

# --- Backups ---
VTORN_BACKUP_DIR=/var/backups/vtorn
# If set, weekly archives are mirrored here (e.g. an rclone-mounted R2/S3 path).
# VTORN_BACKUP_OFFSITE_DIR=/mnt/r2/vtorn-backups

# --- Restore safety ---
# Comma-separated hosts where db-restore.sh is allowed to run without force.
VTORN_RESTORE_ALLOW_HOSTS=localhost,127.0.0.1
# Set to 1 to apply infra/db/pii-scrub.sql after restoring a prod snapshot
# into a lower environment. Default 0.
VTORN_RESTORE_PII_SCRUB=0

# --- Service ports (informational; bound by the services themselves) ---
# Renderer (apps/web) Next.js dev:        3300
# Producer WS (apps/statsbomb-replay):    4001
# Producer WS (apps/mock-producer):       4001 (one at a time)
# API (apps/api):                         3310
# Marketing (apps/marketing, future):     3320

# --- API ---
VTORN_API_PORT=3310
VTORN_API_BIND=0.0.0.0
VTORN_API_CORS_ORIGINS=https://vtorn.aiva.nz,http://localhost:3300

# --- Renderer ---
NEXT_PUBLIC_STREAM_URL=ws://localhost:4001
NEXT_PUBLIC_API_URL=https://vtorn-api.aiva.nz
NEXT_PUBLIC_AUTH_API_URL=http://localhost:3330

# --- Auth service (apps/auth-sms) — see docs/32-auth-and-privacy.md ---
AUTH_PORT=3330
AUTH_BIND=0.0.0.0
AUTH_APP_HOST=tournamental.com
AUTH_PRODUCT_NAME=Tournamental
AUTH_DB_PATH=./apps/auth-sms/data/auth.db
# 32+ char secrets — generate with: openssl rand -hex 32
# (leave blank in .env.example; set real values in .env, never committed)
AUTH_OTP_SECRET=
AUTH_JWT_SECRET=
AUTH_ADMIN_TOKEN=
AUTH_OTP_TTL_SECONDS=600
AUTH_MAX_VERIFY_ATTEMPTS=5
AUTH_SESSION_TTL_SECONDS=2592000

# Telegram Login Widget — reuses the bot whose token tournament-bot uses.
# Set TELEGRAM_BOT_TOKEN to enable POST /v1/auth/telegram/callback.
# TELEGRAM_BOT_USERNAME must match the bot's @username (without the @) and
# is rendered on the widget on the marketing site + bracket app.
# TELEGRAM_BOT_TOKEN=000000000:replace-me-with-real-token
TELEGRAM_BOT_USERNAME=TournamentalBot
# Marketing + bracket app:
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=TournamentalBot
PUBLIC_TELEGRAM_BOT_USERNAME=TournamentalBot

# Aiva SMS gateway (sms.aiva.nz). See clawdia/skills/aiva-sms/SKILL.md.
AIVA_SMS_API_URL=http://localhost:9252
AIVA_SMS_API_KEY=
AIVA_SMS_DEVICE_ID=
# WhatsApp transport: "aiva" (default) or "baileys" (in-process).
WHATSAPP_TRANSPORT=aiva
AIVA_WA_SESSION_ID=
# Only used when WHATSAPP_TRANSPORT=baileys.
BAILEYS_AUTH_DIR=./apps/auth-sms/baileys-auth
BAILEYS_QR_PATH=./apps/auth-sms/baileys-auth/last-qr.png

# --- CRM bridge (apps/crm-bridge) — see apps/crm-bridge/README.md ---
CRM_PORT=3395
CRM_BIND=0.0.0.0
# 'mock' (default) writes to data/ghl-calls.jsonl. 'real' calls
# https://services.leadconnectorhq.com and requires the two GHL_* values
# below; the bridge throws on boot if either is missing.
CRM_BACKEND=mock
GHL_API_KEY=
GHL_LOCATION_ID=
# Optional override (useful for staging/sandbox tenants).
# GHL_API_BASE_URL=https://services.leadconnectorhq.com
# Bearer token required to call POST /v1/admin/replay-failed.
CRM_ADMIN_TOKEN=
# Override the failed-call replay log path (defaults to ./data/ghl-failed.jsonl).
# CRM_GHL_FAILED_LOG_PATH=

# --- Supabase Auth + identity (apps/web → user_profiles, friendships, invite_codes) ---
# Provision the project in the dashboard (https://supabase.com/dashboard) and
# follow docs/52-supabase-setup.md. The anon key is safe to ship in the
# browser bundle; the service-role key is server-only.
#
# When NEXT_PUBLIC_SUPABASE_URL is unset the web client falls back to
# guest-mode (anonymous localStorage session); useful for `pnpm dev`
# without a project provisioned yet.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (apps/web API routes, apps/game JWT verification).
# Generate from Project Settings → API. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Server salt for SHA-256(E.164 phone). 32+ hex chars; keep in Supabase
# Vault for production. Without this salt the hash would be a global
# rainbow-table target. Generate with: openssl rand -hex 32
SUPABASE_PHONE_HASH_SALT=
# JWT signing secret published by Supabase (Project Settings → API → JWT
# Settings → "JWT Secret"). Used by the game service to validate
# Authorization: Bearer <token> requests.
SUPABASE_JWT_SECRET=
# Game service: allow legacy X-User-Id header (set 0 in production).
GAME_DEV_AUTH=1
# Aiva SMS hook secret (Supabase → Authentication → Phone → custom
# provider). Supabase HMAC-signs the SMS-send webhook; we verify.
SUPABASE_SMS_HOOK_SECRET=

# --- Phase-3 commentary (ElevenLabs realtime TTS) ---
# When ELEVENLABS_API_KEY is unset, /api/commentary/sign returns a stub
# response (signed: false) and the renderer mounts a silent buffer so
# the audio mixer + ducking pipeline can still be tested end-to-end.
# Drop a real key here to enable live WSS commentary.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID_EN=
# ELEVENLABS_VOICE_ID_ES=
# ELEVENLABS_MODEL=eleven_turbo_v2_5
