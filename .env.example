# VTorn dev environment template.
# Copy to .env and fill in real values. .env is gitignored.

# --- Application ---
NODE_ENV=development
LOG_LEVEL=info

# --- Database (Postgres 16, dockerised, port 5435) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_DB=vtorn
POSTGRES_USER=vtorn
POSTGRES_PASSWORD=replace-with-a-real-password
DATABASE_URL=postgres://vtorn:replace-with-a-real-password@localhost:5435/vtorn?schema=public

# --- Cache (Redis 7, dockerised, port 6380) ---
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=replace-with-a-real-password
REDIS_URL=redis://:replace-with-a-real-password@localhost:6380

# --- Backups ---
VTORN_BACKUP_DIR=/var/backups/vtorn
# If set, weekly archives are mirrored here (e.g. an rclone-mounted R2/S3 path).
# VTORN_BACKUP_OFFSITE_DIR=/mnt/r2/vtorn-backups

# --- Restore safety ---
# Comma-separated hosts where db-restore.sh is allowed to run without force.
VTORN_RESTORE_ALLOW_HOSTS=localhost,127.0.0.1
# Set to 1 to apply infra/db/pii-scrub.sql after restoring a prod snapshot
# into a lower environment. Default 0.
VTORN_RESTORE_PII_SCRUB=0

# --- Service ports (informational; bound by the services themselves) ---
# Renderer (apps/web) Next.js dev:        3300
# Producer WS (apps/statsbomb-replay):    4001
# Producer WS (apps/mock-producer):       4001 (one at a time)
# API (apps/api):                         3310
# Marketing (apps/marketing, future):     3320

# --- API ---
VTORN_API_PORT=3310
VTORN_API_BIND=0.0.0.0
VTORN_API_CORS_ORIGINS=https://vtorn.aiva.nz,http://localhost:3300

# --- Renderer ---
NEXT_PUBLIC_STREAM_URL=ws://localhost:4001
NEXT_PUBLIC_API_URL=https://vtorn-api.aiva.nz
