{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FIFA WC 2026 Teams",
  "type": "object",
  "required": ["tournament", "teams"],
  "properties": {
    "tournament": { "type": "string" },
    "_note": { "type": "string" },
    "teams": {
      "type": "array",
      "minItems": 48,
      "maxItems": 48,
      "items": { "$ref": "#/$defs/team" }
    }
  },
  "$defs": {
    "team": {
      "type": "object",
      "required": ["code", "name", "kit", "qualified"],
      "properties": {
        "code": { "type": "string", "minLength": 2, "maxLength": 5 },
        "name": { "type": "string" },
        "short_name": { "type": "string" },
        "confederation": {
          "type": "string",
          "enum": ["AFC", "CAF", "CONCACAF", "CONMEBOL", "OFC", "UEFA", "TBD"]
        },
        "flag_emoji": { "type": "string" },
        "flag_svg_url": { "type": "string" },
        "kit": {
          "type": "object",
          "required": ["primary", "secondary"],
          "properties": {
            "primary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
            "secondary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
          }
        },
        "fifa_ranking_at_2026": { "type": ["integer", "null"] },
        "manager": { "type": ["string", "null"] },
        "wikidata_q": { "type": ["string", "null"] },
        "qualified": { "type": "boolean" },
        "qualification_path": { "type": "string" },
        "is_host": { "type": "boolean" },
        "_note": { "type": "string" }
      }
    }
  }
}
