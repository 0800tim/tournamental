{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FIFA WC 2026 Players",
  "type": "object",
  "required": ["tournament", "players"],
  "properties": {
    "tournament": { "type": "string" },
    "_note": { "type": "string" },
    "roster_format_version": { "type": "string" },
    "players": {
      "type": "array",
      "items": { "$ref": "#/$defs/player" }
    }
  },
  "$defs": {
    "player": {
      "type": "object",
      "required": ["player_id", "name", "country"],
      "properties": {
        "player_id": { "type": "string" },
        "name": { "type": "string" },
        "number": { "type": ["integer", "null"], "minimum": 1, "maximum": 99 },
        "country": { "type": "string" },
        "wikidata_q": { "type": ["string", "null"] },
        "image_url": { "type": ["string", "null"] },
        "attribution": { "type": ["string", "null"] },
        "pre_tournament": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
