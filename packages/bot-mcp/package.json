{
  "name": "@tournamental/bot-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for the Tournamental Open Bot Arena. Lets any MCP-compatible AI client (Claude Desktop, Cursor, etc.) play in the FIFA World Cup 2026 prediction tournament.",
  "keywords": [
    "tournamental",
    "mcp",
    "model-context-protocol",
    "bot-arena",
    "world-cup-2026",
    "claude-desktop",
    "cursor",
    "predictions"
  ],
  "homepage": "https://play.tournamental.com/bots/sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/0800tim/tournamental.git",
    "directory": "packages/bot-mcp"
  },
  "bugs": "https://github.com/0800tim/tournamental/issues",
  "author": "Tim Thomas <0800tim@gmail.com>",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "tournamental-bot-mcp": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "example-claude-desktop-config.json",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@tournamental/bot-sdk": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  }
}
