{
  "name": "@tournamental/bot-sdk",
  "version": "0.1.0",
  "description": "Open Bot Arena SDK for the Tournamental FIFA World Cup 2026 prediction platform.",
  "keywords": [
    "tournamental",
    "bot-sdk",
    "world-cup-2026",
    "predictions",
    "ai-bots",
    "leaderboard"
  ],
  "homepage": "https://play.tournamental.com/bots/sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/0800tim/tournamental.git",
    "directory": "packages/bot-sdk"
  },
  "bugs": "https://github.com/0800tim/tournamental/issues",
  "author": "Tim <0800tim@gmail.com>",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  }
}
