{
  "name": "@tournamental/social-cards",
  "version": "0.1.0",
  "description": "Framework-agnostic OG, podium and share-card generator for Tournamental. Built on satori, @resvg/resvg-js and @napi-rs/canvas.",
  "keywords": [
    "tournamental",
    "og-image",
    "share-card",
    "social-cards",
    "world-cup-2026",
    "satori"
  ],
  "homepage": "https://tournamental.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/0800tim/tournamental.git",
    "directory": "packages/social-cards"
  },
  "bugs": "https://github.com/0800tim/tournamental/issues",
  "author": "Tim <0800tim@gmail.com>",
  "license": "Apache-2.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./cards": "./src/cards/index.ts",
    "./theme": "./src/theme.ts",
    "./fonts": "./src/fonts.ts",
    "./canvas": "./src/canvas/index.ts",
    "./video": "./src/video/index.ts"
  },
  "files": [
    "dist",
    "src",
    "fonts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "./cards": {
        "import": {
          "types": "./dist/cards/index.d.mts",
          "default": "./dist/cards/index.mjs"
        },
        "require": {
          "types": "./dist/cards/index.d.ts",
          "default": "./dist/cards/index.js"
        }
      },
      "./theme": {
        "import": {
          "types": "./dist/theme.d.mts",
          "default": "./dist/theme.mjs"
        },
        "require": {
          "types": "./dist/theme.d.ts",
          "default": "./dist/theme.js"
        }
      },
      "./fonts": {
        "import": {
          "types": "./dist/fonts.d.mts",
          "default": "./dist/fonts.mjs"
        },
        "require": {
          "types": "./dist/fonts.d.ts",
          "default": "./dist/fonts.js"
        }
      },
      "./canvas": {
        "import": {
          "types": "./dist/canvas/index.d.mts",
          "default": "./dist/canvas/index.mjs"
        },
        "require": {
          "types": "./dist/canvas/index.d.ts",
          "default": "./dist/canvas/index.js"
        }
      },
      "./video": {
        "import": {
          "types": "./dist/video/index.d.mts",
          "default": "./dist/video/index.mjs"
        },
        "require": {
          "types": "./dist/video/index.d.ts",
          "default": "./dist/video/index.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.55",
    "@resvg/resvg-js": "^2.6.2",
    "qrcode": "^1.5.4",
    "satori": "^0.10.13"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/qrcode": "^1.5.5",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
