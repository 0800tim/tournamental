{
  "name": "@vtorn/avatar",
  "version": "0.1.0",
  "private": true,
  "description": "Tournamental procedural avatar pipeline (body GLB + jersey textures + billboard faces)",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./jersey": "./src/jersey-texture.ts",
    "./body": "./src/body-model.ts",
    "./face": "./src/billboard-face.tsx"
  },
  "scripts": {
    "build:assets": "node scripts/build-assets.mjs",
    "build:players": "node scripts/build-players-csv.mjs",
    "demo:jersey": "node scripts/render-jersey-demo.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tournamental/spec": "workspace:*"
  },
  "peerDependencies": {
    "@react-three/drei": ">=9",
    "@react-three/fiber": ">=8",
    "react": ">=18",
    "three": ">=0.160"
  },
  "devDependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.12",
    "@types/three": "^0.184.1",
    "react": "^18.3.1",
    "three": "^0.184.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  }
}
