{
  "name": "@tournamental/bot-node",
  "version": "0.1.0",
  "description": "Federated Tournamental Bot Node: run your own bot swarm, commit merkle roots pre-kickoff, report aggregates post-match. Apache 2.0.",
  "keywords": [
    "tournamental",
    "bot",
    "federated",
    "world-cup-2026",
    "prediction",
    "merkle",
    "bracket"
  ],
  "homepage": "https://tournamental.com/bots/sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/0800tim/tournamental.git",
    "directory": "packages/bot-node"
  },
  "bugs": "https://github.com/0800tim/tournamental/issues",
  "author": "Tim <0800tim@gmail.com>",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tournamental-bot-node": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "Dockerfile",
    "docker-compose.yml",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "fastify": "^5.1.0",
    "undici": "^7.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
