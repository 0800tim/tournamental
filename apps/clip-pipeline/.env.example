# clip-pipeline service config — copy to .env and edit as needed.

# HTTP server.
CLIP_PORT=3380
CLIP_BIND=0.0.0.0

# On-disk root for rendered clips (clip_id is the filename stem).
CLIP_STORAGE_PATH=./apps/clip-pipeline/data/clips

# ffmpeg binary (resolved on PATH if not absolute).
CLIP_FFMPEG_BIN=ffmpeg

# Public URL prefix for `GET /v1/clip/:id` responses. Blank in dev → falls back
# to the local file:// path so the dashboard can show a clickable link.
CLIP_STORAGE_URL=

# Logging.
CLIP_LOG_LEVEL=info

# Auto-trigger persistence + downstream publisher.
CLIP_ACTIVE_TRIGGERS_PATH=./apps/clip-pipeline/data/active-triggers.jsonl
CLIP_FAILED_PUBLISHES_PATH=./apps/clip-pipeline/data/failed-publishes.jsonl
CLIP_PUBLISHER_BASE_URL=http://localhost:3382
