# Rendered clips are content-addressed by SHA — reproducible from inputs,
# never committed.
data/clips/*.mp4
data/clips/*.jpg
data/clips/*.webp
data/clips/*.png

# Auto-trigger runtime state is per-deployment, never committed.
data/active-triggers.jsonl
data/failed-publishes.jsonl

# tsc build artefacts.
dist/
*.tsbuildinfo
