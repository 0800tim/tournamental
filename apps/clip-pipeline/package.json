{
  "name": "@vtorn/clip-pipeline",
  "version": "0.0.1",
  "private": true,
  "description": "Highlight detection + ffmpeg clip render service for Tournamental social distribution",
  "type": "module",
  "bin": {
    "clip-pipeline": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prestart": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.test.json",
    "dump-openapi": "tsx scripts/dump-openapi.ts",
    "openapi:snapshot": "pnpm run dump-openapi"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@vtorn/spec": "workspace:*",
    "fastify": "^5.1.0",
    "pino": "^9.5.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
