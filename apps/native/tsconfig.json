{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "declaration": false,
    "sourceMap": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    "capacitor.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "www",
    "ios",
    "android",
    "resources/icon",
    "resources/splash"
  ]
}
