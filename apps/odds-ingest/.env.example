# odds-ingest service configuration template.
# Copy to .env and fill in real values. .env is gitignored.

# --- HTTP server ---
ODDS_INGEST_PORT=3340
ODDS_INGEST_BIND=0.0.0.0

# --- Storage ---
# SQLite file. Relative paths resolve from the repo root.
ODDS_INGEST_DB_PATH=./data/odds-ingest.sqlite

# --- Logging ---
LOG_LEVEL=info

# --- Polymarket (no auth required for read-only) ---
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
# Comma-separated tag slugs we care about. The Gamma API exposes a /tags endpoint;
# the actual slug for the 2026 World Cup may need confirmation closer to launch.
POLYMARKET_TAG_SLUGS=fifa-world-cup,fifa-2026,world-cup-2026

# --- The Odds API (free 500 req/month tier — register at https://the-odds-api.com/) ---
# If unset, the secondary source falls back to mock data.
THE_ODDS_API_BASE=https://api.the-odds-api.com/v4
THE_ODDS_API_KEY=

# --- Polling cadence (milliseconds) ---
POLL_GAMMA_MS=300000
POLL_CLOB_MS=30000
POLL_THE_ODDS_API_MS=3600000

# --- Source enablement ---
SOURCE_POLYMARKET_ENABLED=true
SOURCE_THE_ODDS_API_ENABLED=true
SOURCE_MOCK_ENABLED=true
