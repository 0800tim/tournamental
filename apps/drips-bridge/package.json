{
  "name": "@vtorn/drips-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Tournamental Drips Network bridge \u2014 contributor revenue-split scaffold + mock Drips client (Apache-2.0 contributors share platform revenue per the pitch)",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prestart": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dump-openapi": "tsx scripts/dump-openapi.ts",
    "openapi:snapshot": "pnpm run dump-openapi"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "fastify": "^5.0.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "tsx": "^4.22.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
