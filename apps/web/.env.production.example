# apps/web - production environment template.
#
# Copy to apps/web/.env.production (or set via your deploy platform's
# secret manager) before going live. The signup funnel will not push
# contacts to GHL without the two GHL_* values below.

NODE_ENV=production

# --- GoHighLevel CRM ---
# Required for the syndicate-owner contact sync.
GHL_API_KEY=
GHL_LOCATION_ID=

# --- Public origin ---
NEXT_PUBLIC_PLAY_HOST=https://play.tournamental.com

# --- Shared SQLite store ---
# Should point at the same path apps/game uses in production.
GAME_DB_PATH=/var/lib/tournamental/game.db

# --- Live prediction-market odds (apps/odds-ingest) ---
# Public base URL of the odds-ingest service. Inlined into the client
# bundle and called from the browser, so it must be HTTPS with open CORS.
# When unset, the bracket silently falls back to the FIFA-rank mock and
# shows WRONG numbers (e.g. MEX 85% instead of the real ~66%), so this
# MUST be set in production for the odds to match Polymarket.
NEXT_PUBLIC_ODDS_API_URL=https://odds.tournamental.com
# Optional internal override for the SSR /api/odds/* proxy.
# ODDS_API_URL=http://127.0.0.1:3341
