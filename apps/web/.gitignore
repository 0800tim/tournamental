
# Owner-uploaded syndicate branding (logos, hero images)
data/branding/

# User-uploaded avatars (PII -- keyed by user_id)
data/avatars/

# Stray accidental dirs from $HOME path typos
home/

# Local test-runtime artefacts
tmp/

# Server-generated OG image cache (rendered on first request, then
# refreshed by satori). Don't commit the rasterised stamps.
public/og/syndicate/
public/og/bracket/
