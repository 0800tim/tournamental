    "@react-three/postprocessing": "2.19.1",
    "@react-three/rapier": "1.5.0",
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tournamental/bracket-engine": "workspace:*",
    "@tournamental/social-cards": "workspace:*",
    "@tournamental/spec": "workspace:*",
    "@tournamental/spec-client": "workspace:*",
    "@vtorn/avatar": "workspace:*",
    "@vtorn/ball-physics": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "country-flag-icons": "^1.6.17",
    "gsap": "^3.13.0",
    "html-to-image": "^1.11.13",
