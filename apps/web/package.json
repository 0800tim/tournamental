{
  "name": "@vtorn/web",
  "version": "0.0.0",
  "private": true,
  "description": "Tournamental 3D match renderer (Next.js + React Three Fiber)",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3300",
    "build": "NODE_ENV=production next build",
    "start": "next start -p 3300",
    "lint": "next lint --dir app --dir components --dir lib --dir __tests__",
