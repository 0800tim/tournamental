{
  "name": "@vtorn/web",
  "version": "0.0.0",
  "private": true,
  "description": "VTourn 3D match renderer (Next.js + React Three Fiber)",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3300",
    "build": "next build",
    "start": "next start -p 3300",
    "lint": "next lint --dir app --dir components --dir lib --dir __tests__",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@resvg/resvg-js": "^2.6.2",
    "@vtorn/avatar": "workspace:*",
    "@vtorn/bracket-engine": "workspace:*",
    "@vtorn/spec": "workspace:*",
    "@vtorn/spec-client": "workspace:*",
    "country-flag-icons": "^1.6.17",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "satori": "^0.26.0",
    "three": "^0.184.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
