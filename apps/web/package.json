    "@testing-library/react": "^16.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
