# apps/web, environment variables.
#
# Most repo-wide env vars live in the root .env at the repo top, see
# /.env.example for the canonical list. This file calls out only the
# variables the @vtorn/web service reads directly. Copy to .env at
# repo root (or apps/web/.env.local for dev overrides) and fill in.

# ----------------------------------------------------------------------
# Syndicate signup (apps/web/app/syndicates/new) + GHL contact sync.
#
# The signup route (POST /api/v1/syndicates) forwards new syndicate
# owners to GoHighLevel as contacts with the `syndicate_owner` tag
# and the following custom fields:
#   - syndicate_slug
#   - syndicate_role=owner
#   - syndicate_tournament
#
# When GHL_API_KEY is unset, the route logs a warning and still
# creates the syndicate row (ghl_status=skipped). Failures during the
# live push are written to the syndicates_pending_ghl SQLite table
# for a daily retry cron to replay.
# ----------------------------------------------------------------------
GHL_API_KEY=
GHL_LOCATION_ID=
# Optional sandbox/staging override.
# GHL_API_BASE_URL=https://services.leadconnectorhq.com

# Public origin used to build invite URLs in the success card and the
# share_url field of the create-syndicate response. Defaults to
# https://play.tournamental.com.
# NEXT_PUBLIC_PLAY_HOST=https://play.tournamental.com

# ----------------------------------------------------------------------
# Approve/deny email link secret (SEC-POOL-03 / SEC-WEB-04).
#
# Dedicated HMAC secret for the approve/deny links the pool owner
# receives via email when a join request lands. Decoupled from
# AUTH_JWT_SECRET so each can rotate without invalidating the other,
# and so the approve link can carry an `iat` claim + 72h TTL.
#
# Required for the email-link path; the in-dashboard approve UI works
# without it. Use a 64+ char random string.
# ----------------------------------------------------------------------
APPROVAL_TOKEN_SECRET=

# ----------------------------------------------------------------------
# Admin-impersonate manage-token verify secret.
#
# apps/admin's /api/admin/syndicates/[slug]/impersonate mints a manage
# JWT signed with this secret so a Tim-tier admin can step into a pool
# owner's dashboard without holding the owner's OTP. The web app then
# verifies that token against ADMIN_MANAGE_JWT_SECRET FIRST, and falls
# back to AUTH_JWT_SECRET (the user-issued manage-token path via
# /manage-auth). Keep the two secrets distinct so admin tokens can
# rotate without bumping every active owner session.
# Generate: openssl rand -hex 32
# ----------------------------------------------------------------------
ADMIN_MANAGE_JWT_SECRET=CHANGE_ME

# Shared SQLite store path. The syndicate route opens the same DB
# file the game service migrates. Defaults to ./apps/game/data/game.db.
# GAME_DB_PATH=./apps/game/data/game.db

# ----------------------------------------------------------------------
# Live prediction-market odds (apps/odds-ingest)
# ----------------------------------------------------------------------
# Base URL of the odds-ingest service. When set, the bracket odds chip
# pulls REAL Polymarket-derived W/D/L, group-winner and tournament-winner
# probabilities from this service (Tier 1). When unset, the client falls
# back to the local /api/odds/* stub and finally to the deterministic
# FIFA-rank mock, so the chip always renders something.
#
# This is a NEXT_PUBLIC_* var: it is inlined into the client bundle and
# called from the browser, so the service must be reachable over HTTPS
# with permissive CORS (odds-ingest sets Access-Control-Allow-Origin: *).
#
# Dev (odds-ingest running locally on its default port):
#   NEXT_PUBLIC_ODDS_API_URL=http://127.0.0.1:3341
# Dev via tunnel / prod hostname:
#   NEXT_PUBLIC_ODDS_API_URL=https://odds.tournamental.com
#
# Optional server-only override used by the /api/odds/* route handlers
# (takes precedence over NEXT_PUBLIC_ODDS_API_URL inside the route). Use
# this to point the SSR proxy at an internal address while the browser
# uses the public hostname.
#   ODDS_API_URL=http://127.0.0.1:3341
NEXT_PUBLIC_ODDS_API_URL=
