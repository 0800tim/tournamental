# Tournamental push-notifications service — sample env. Copy to .env and fill in.

# ---------- service ----------
PUSH_PORT=3398
PUSH_BIND=0.0.0.0
LOG_LEVEL=info
PUSH_CORS_ORIGINS=https://tournamental.com,https://2026wc.tournamental.com,https://play.tournamental.com,http://localhost:3300

# Optional shared secret. If set, all /v1/notify/* routes require
# `x-push-secret: <this value>`. Strongly recommended in production.
PUSH_INTERNAL_SECRET=

# ---------- Web Push (W3C) ----------
# Generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@tournamental.com

# ---------- Telegram ----------
# Either provide the bot token (direct send) or the tournament-bot push URL.
TELEGRAM_BOT_TOKEN=
TOURNAMENT_BOT_PUSH_URL=
TOURNAMENT_BOT_PUSH_SECRET=

# ---------- SMS (Aiva SMS gateway) ----------
AIVA_SMS_API_URL=http://localhost:9252
AIVA_SMS_API_KEY=
AIVA_SMS_DEVICE_ID=
