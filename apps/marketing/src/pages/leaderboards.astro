import Layout from "@/layouts/Layout.astro";
import EditorialPageHeader from "@/components/EditorialPageHeader.astro";
import LeaderboardDemo from "@/components/LeaderboardDemo.astro";
import EditorialStatGrid from "@/components/EditorialStatGrid.astro";
import PrincipleList from "@/components/PrincipleList.astro";

/**
 * /leaderboards, lifted to editorial calibre.
 *
 * Page opens with an EditorialPageHeader (dateline + Fraunces head +
 * italic lede + footnote). The existing LeaderboardDemo card sits in
 * a wider editorial frame: a "Live preview" mono caption above it and
 * a small dateline caption underneath the card explaining the
 * placeholder. The Three Scopes admin table is rebuilt as an
 * EditorialStatGrid (hairline rules, no card chrome, gold masthead
 * bar). Closing principles use the PrincipleList stack so the
 * anti-bot + pay-to-win commitments read as part of the editorial
 * argument rather than a tacked-on prose footer.
 */

const SCOPE_COLUMNS = ["Scope", "All-time", "Season", "Weekly"] as const;
const SCOPE_ROWS = [
  {
    label: "Global",
    meta: "Country tagged, public",
    cells: ["Top 10,000", "Top 10,000", "Top 1,000"],
  },
  {
    label: "Country",
    meta: "By passport / sign-up flag",
    cells: ["Top 1,000", "Top 1,000", "Top 250"],
  },
  {
    label: "Tournament",
    meta: "Scoped to the running event",
    cells: ["—", "—", "All players"],
  },
  {
    label: "Syndicate",
    meta: "Private, host-owned",
    cells: ["All members", "All members", "All members"],
  },
] as const;

const COMMITMENTS = [
  {
    index: "01",
    heading: "Anti-bot, pro-fan",
    body:
      "A Humanness Score (per the open-source spec) prevents bot accounts from gaming the boards. If we suspect inauthentic behaviour, payouts and badge unlocks clamp until verification. The score reads cross-provider OAuth signals (Telegram, Discord, Apple, Google) plus optional contacts-cluster verification. We never sell who you know.",
  },
  {
    index: "02",
    heading: "No pay to win",
    body:
      "There is no way to buy points. There is no way to buy a leaderboard slot. Bonus tokens come from playing, sharing, and referring. The whole scoring spec is on GitHub, audit it yourself.",
  },
  {
    index: "03",
    heading: "Scoring you can read",
    body:
      "Base points for a correct call, scaled by how unlikely it was at lock-in. Streaks compound. Brier-scored Prediction IQ follows you across tournaments. The exact formulas are in the open spec under /open-source.",
  },
] as const;
---
<Layout
  title="Leaderboards · Tournamental"
  description="Global, country and friend-group leaderboards across every tournament. Live during a tournament, archival between them, all on a single open ledger."
  ogImage="/og/leaderboards.png"
>
  <section class="vt-editorial">
    <div class="container-page">
      <EditorialPageHeader
        dateline="Leaderboards · World Cup 2026 · v1"
        title=""
        lede="The whole world is on the global board. Your country is on the country board. Your office, your group chat, your fan club is on its own. They all settle from a single ledger as matches finish."
        footnote="Updates every minute at kickoff · Archives between tournaments"
      >
        <Fragment slot="title">
          Three scopes. <em>One</em> ledger.
        </Fragment>
      </EditorialPageHeader>
    </div>
  </section>

  <section class="vt-editorial container-page pb-16 md:pb-20">
    <figure class="vt-lb-figure">
      <figcaption class="vt-lb-figcap">
        <span class="vt-dateline">Live preview · Global, World Cup 2026</span>
        <p class="vt-lede vt-lb-figcap-lede">
          A snapshot of the global board, fixed at five entries so the
          page renders the same on every build. The live board opens at
          the opener and reorders every minute through the final.
        </p>
      </figcaption>
      <div class="vt-lb-frame">
        <LeaderboardDemo />
      </div>
      <figcaption class="vt-footnote vt-lb-footnote">
        Illustrative data. Reordered from the production schema, no real
        player handles. The live URL is <code>play.tournamental.com/top</code>.
      </figcaption>
    </figure>
  </section>

  <section class="vt-editorial container-page pb-16 md:pb-20">
    <header class="mb-8 md:mb-10">
      <span class="vt-dateline">Scope table · Read across</span>
      <h2 class="vt-section-head mt-3">
        Four scopes, three timeframes, one game.
      </h2>
      <p class="vt-lede mt-5">
        The depth of the board changes with the scope. Global keeps the
        top ten thousand, country the top thousand, tournament settles a
        single event, syndicate shows every member of a private pool.
      </p>
    </header>

    <EditorialStatGrid columns={SCOPE_COLUMNS} rows={SCOPE_ROWS} />
  </section>

  <section class="vt-editorial container-page pb-16 md:pb-24">
    <header class="mb-10 md:mb-12">
      <span class="vt-dateline">Three commitments · Why the board is trusted</span>
      <h2 class="vt-section-head mt-3">
        The leaderboard is the product. It earns its place.
      </h2>
    </header>
    <PrincipleList items={COMMITMENTS} />
  </section>
</Layout>

<style>
  .vt-lb-figure {
    margin: 0;
    display: grid;
    gap: 1.25rem;
  }
  .vt-lb-figcap {
    display: grid;
    gap: 0.85rem;
    max-width: 60ch;
  }
  .vt-lb-figcap-lede {
    margin: 0;
  }
  .vt-lb-frame {
    max-width: 38rem;
  }
  .vt-lb-footnote {
    margin: 0;
    max-width: 60ch;
  }
  .vt-lb-footnote code {
    background: transparent;
    color: var(--vt-fg);
    border-bottom: 1px dotted var(--vt-gold-400);
    padding: 0;
    font-size: inherit;
  }
</style>
