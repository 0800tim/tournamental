---
/**
 * /syndicates/playbook — moved to play.tournamental.com.
 *
 * The long-form playbook lives on the play app alongside the
 * dashboard and creation flow. This page bounces to the canonical
 * location with the query string preserved for any deep-link
 * references.
 */
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Syndicate playbook · Tournamental</title>
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content="0; url=https://play.tournamental.com/syndicates/playbook" />
    <link rel="canonical" href="https://play.tournamental.com/syndicates/playbook" />
  </head>
  <body>
    <script is:inline>
      (function () {
        try {
          var search = window.location.search || "";
          var hash = window.location.hash || "";
          window.location.replace("https://play.tournamental.com/syndicates/playbook" + search + hash);
        } catch (e) {
          window.location.href = "https://play.tournamental.com/syndicates/playbook";
        }
      })();
    </script>
    <noscript>
      <p>The syndicate playbook has moved. <a href="https://play.tournamental.com/syndicates/playbook">Open the Tournamental play app</a>.</p>
    </noscript>
  </body>
</html>
