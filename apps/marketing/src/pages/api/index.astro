---
/**
 * /api, aggregated Tournamental API reference.
 *
 * Mounts Scalar API Reference against the build-time bundle at
 * `/api/openapi-bundle.json`. Scalar (MIT) gives us a single-page
 * three-pane reference (sidebar tags, middle docs, right code-samples)
 * that handles 50+ endpoints across 9+ services on a 360px viewport
 * without modifications.
 *
 * The bundle is regenerated by `scripts/build-openapi-index.mjs` on
 * every marketing build. When the upstream Fastify services are offline
 * the aggregator falls back to the committed snapshots in `docs/api/`.
 *
 * Per-service deep links live at `/api/<slug>` and filter the same
 * bundle. See `docs/53-api-portal.md` for the full architecture.
 */
import Layout from "@/layouts/Layout.astro";
import manifest from "../../../public/api/manifest.json";

const services = (manifest as { services: Array<{ slug: string; name: string; description: string; pkg: string; auth: string; mode: string; paths: number }> }).services;
const builtAt = (manifest as { builtAt: string }).builtAt;
---
<Layout
  title="API reference · Tournamental"
  description="Public Tournamental API. Every Fastify service in the open-source monorepo, in one searchable reference, with code samples and authentication notes."
  ogImage="/og/contribute.png"
>
  <section class="container-page pt-16 pb-8">
    <p class="uppercase tracking-widest text-xs text-ink-200 mb-3">API reference</p>
    <h1 class="text-3xl md:text-5xl font-bold text-white">Tournamental Public API</h1>
    <p class="text-ink-200 mt-3 max-w-3xl">
      Every public Fastify service from the open-source monorepo, in one
      reference. Built from the live services when reachable, with the
      committed snapshots in <code>docs/api/</code> as the offline fallback.
    </p>
    <p class="text-ink-500 text-sm mt-2">
      Last built: <time datetime={builtAt}>{builtAt}</time>. Apache-2.0 licensed.
      Code samples in cURL, JavaScript, and Python.
    </p>
    <div class="flex flex-wrap gap-3 mt-5">
      <a href="https://github.com/0800tim/tournamental" class="btn-primary">Source repo</a>
      <a href="/api/openapi-bundle.json" class="btn-ghost">Download bundle (JSON)</a>
      <a href="/contribute" class="btn-ghost">Contribute</a>
    </div>
  </section>

  <section class="container-page pb-10">
    <h2 class="text-xl font-bold text-white mb-3">Services in this bundle</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {services.map((s) => (
        <a class="card hover:border-ink-600 transition-colors" href={`/api/${s.slug}`}>
          <div class="flex items-center justify-between">
            <h3 class="font-bold text-white">{s.name}</h3>
            <span class="text-[10px] uppercase tracking-wider text-ink-500">{s.mode}</span>
          </div>
          <p class="text-ink-200 mt-1 text-sm">{s.description}</p>
          <p class="text-ink-500 mt-2 text-xs">
            <code>{s.pkg}</code> · {s.paths} {s.paths === 1 ? "path" : "paths"} · auth: {s.auth}
          </p>
        </a>
      ))}
    </div>
  </section>

  <section class="container-page pb-16">
    {/*
      Scalar API Reference is mounted on a div with the right data
      attribute. We pin the version so a Scalar release can't quietly
      reshape our portal. Mobile: Scalar handles narrow viewports out of
      the box; the wrapper just gives it a min-height so the loading
      shimmer isn't a 0-height flash.
    */}
    <div id="scalar-wrap" class="min-h-[60vh] rounded-xl overflow-hidden border border-ink-800 bg-ink-900">
      <script
        is:inline
        id="api-reference"
        data-url="/api/openapi-bundle.json"
        data-configuration={JSON.stringify({
          theme: "purple",
          layout: "modern",
          hideDownloadButton: false,
          searchHotKey: "k",
          metaData: {
            title: "Tournamental Public API",
          },
        })}
      ></script>
      <script
        src="https://cdn.jsdelivr.net/npm/@scalar/api-reference@1.25.116/dist/browser/standalone.js"
        crossorigin="anonymous"
        is:inline
        defer
      ></script>
    </div>
  </section>
</Layout>
