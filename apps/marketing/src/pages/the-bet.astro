 * see LICENSE in the repo root for the canonical text.
 */
import Layout from "@/layouts/Layout.astro";
import EditorialPageHeader from "@/components/EditorialPageHeader.astro";

/**
 * /the-bet, Tim's house-prize promotion long-form.
 *
 * Punchy first-person voice. The mortgage disclosure and the no-insurance
 * commitment are woven into the body, not buried in footnotes. Links to
 * /odds for the maths and /verify for the on-chain audit trail. Linked
 * from the homepage prize card and from the press release.
 */

const TITLE = "I'm betting my house on it · Tournamental";
const DESCRIPTION =
  "Predict all 104 FIFA World Cup match outcomes and I'll sign over my house. NZ$1.4M property, NZ$800k mortgage, NZ$600k net equity to the winner. Open to NZ residents 18+. Free to enter.";
---
<Layout title={TITLE} description={DESCRIPTION}>
  <article class="vt-editorial container-page">
    <EditorialPageHeader
      dateline="The bet · Auckland · World Cup 2026"
      title="I'm betting <em>my house</em> on it."
      lede="If you can predict every one of the 104 matches at the 2026 World Cup, I'll sign over what's left of my equity."
      footnote="Open to New Zealand residents 18 and over. Free to enter. Picks lock at each match's kickoff."
    />

    <section class="vt-bet-body">
      <p class="vt-bet-lead">
        I'm Tim Thomas. New Zealand engineer. Twenty-six years building
        websites and apps. The last three weeks of those years, I built a
        FIFA World Cup prediction game.
      </p>

      <p>
        If you can beat it, if you can predict every one of the 104 matches
        at the 2026 World Cup correctly, I'll sign over my house.
      </p>

      <p>
        It's worth NZ$1.4 million.
      </p>

      <div class="vt-bet-callout">
        <p class="vt-bet-callout-head">Quick honesty break.</p>
        <p>
          I still owe the bank NZ$800,000 on the mortgage. So the actual
          prize is the equity. I sell the house, settle the mortgage, you
          walk away with roughly <strong>NZ$600,000 cash</strong>.
        </p>
        <p>
          That's still life-changing money. It's also literally every
          dollar I have in property. I'm not bluffing.
        </p>
      </div>

      <p>
        Open to NZ residents 18 and over. Free to enter. No catch except
        this: your picks lock at the kickoff of each match. You can't
        watch the goal go in and change your mind.
      </p>

      <p>
        If one person, anywhere in this country, predicts every one of
        the 104 matches correctly through <a href="https://play.tournamental.com">Tournamental.com</a>, I list
        the house, settle the bank, and wire the rest to their account.
      </p>

      <h2 class="vt-bet-h2">You're not locked in at the start.</h2>
      <p>
        Every other big bracket game (ESPN, Yahoo, The Telegraph) locks
        every one of your picks in the moment the first match kicks off
        and never lets you touch them again. Tournamental does not. Each
        match is its own decision window, open right up until that match
        kicks off. Save five picks tonight, come back in a week and
        change your mind on every one of them, predict the next thirty
        as the tournament unfolds. You only need every pick locked in by
        the kickoff of its own match.
      </p>

      <h2 class="vt-bet-h2">Worried? No.</h2>
      <p>
        104 matches. Three outcomes each that count as a pick: home win,
        draw, away win.
      </p>
      <p>
        Three to the power of one hundred and four is a number with
        <strong>fifty digits</strong>. <a href="/odds">See the maths</a>.
      </p>
      <p>
        ESPN have run a March Madness bracket challenge since 1998.
        Millions of entries a year. 63 games to predict.
        <strong>Nobody has ever submitted a perfect bracket.</strong> Mine
        has 104.
      </p>
      <p>
        Even smart picks (Brazil over Tahiti, France not losing to Tunisia
        in the group stage) don't dent that headline number. The maths is
        on my side. Loudly.
      </p>

      <h2 class="vt-bet-h2">I'm not insured.</h2>
      <p>
        You can buy prize-indemnity insurance for promotions like this.
        Specialist brokers underwrite the financial tail risk for a small
        premium and if the million-to-one outcome lands, the insurer pays
        out, not the promoter.
      </p>
      <p>
        I'm not doing that.
      </p>
      <p>
        If somebody nails 104-for-104, the bank gets paid out of the sale,
        the winner gets the cheque, and <strong>I'm moving back in with
        mum at age 50!</strong> No underwriter is holding the bag. It's
        just me and my mortgage.
      </p>
      <p>
        I'm not insured because I don't need to be. I built the system,
        I know the maths, and I'd rather skin in the game than skin in an
        insurance broker's fine print.
      </p>

      <h2 class="vt-bet-h2">"Yeah but can't you just change the database?"</h2>
      <p>
        Smart question. You shouldn't trust me; you should trust the code,
        it's 100% open-source.
      </p>
      <p>
        Every match kickoff, Tournamental hashes the predictions database
        and commits the hash to <strong>Bitcoin</strong> via OpenTimestamps.
        The script that does this is open-source. The chain of hashes is
        public at <a href="https://play.tournamental.com/verify">play.tournamental.com/verify</a>.
      </p>
      <p>
        If I change a single pick after kickoff, yours, mine, anyone's,
        the new hash won't match the on-chain commitment and the tampering
        is immediately obvious to anyone with <code>ots verify</code> and
        three minutes.
      </p>
      <p>
        I built the audit trail before I made the bet. The chain of
        custody is public. The script is open-source. I literally cannot
        cheat my own system without everyone watching it happen.
      </p>

      <h2 class="vt-bet-h2">Why am I doing this?</h2>
      <p>
        The World Cup is the biggest sporting event on Earth. The
        prediction game is the perfect engagement vehicle. Tournamental
        is the best one I could possibly build.
      </p>
      <p>
        I'm proud of it. I want people to play it.
      </p>
      <p>
        The fastest way for one Kiwi developer to be heard above five
        thousand other product launches in June 2026 is to put my house
        on the line and mean it. Done.
      </p>
      <p>
        Side note: I built this in three weeks. That part shouldn't be
        possible either. AI coding tools changed what one developer can
        ship. The whole thing, sign-in, brackets, leaderboards, the 3D
        match renderer, 21 languages, the Bitcoin audit trail, was one
        person at a laptop.
      </p>
      <p>
        If you're in the New Zealand tech industry and you're reading
        this thinking "wait, three weeks?", yes. Three weeks. Welcome
        to 2026.
      </p>

      <h2 class="vt-bet-h2">How to enter</h2>
      <ol class="vt-bet-steps">
        <li>
          Go to <a href="https://play.tournamental.com/world-cup-2026">play.tournamental.com/world-cup-2026</a>
          before kickoff on <strong>11 June 2026</strong>.
        </li>
        <li>
          Pick your permanent <code>@handle</code>. That becomes your
          share URL, <code>tournamental.com/s/yourhandle</code>.
        </li>
        <li>
          Predict all 104 matches. Take your time, or pick them in a flash
          with <strong>auto-pick</strong> then change them as you please
          during the tournament. Pull data, follow Polymarket, ask friends,
          run simulations. You're in control and can change picks for each
          individual match right up until that match's kickoff time.
        </li>
        <li>
          If you nail every single one, the keys (well, the proceeds) are
          yours, subject to identity and residency verification.
        </li>
      </ol>
      <p>
        Miss even one and you don't get the equity. You do get five weeks
        on a live leaderboard, watching your bracket render in 3D,
        hammering your mates about the picks they got wrong, and free
        bragging rights for the rest of the year. Not the worst
        consolation prize.
      </p>

      <h2 class="vt-bet-h2">The fine print</h2>
      <p>
        Full terms at <a href="/terms/house-prize">tournamental.com/terms/house-prize</a>.
      </p>
      <p>
        Short version: NZ residents 18+, one bracket per person, you must
        register with a valid NZ mobile phone number. Picks lock at each
        match's kickoff. The prize is the <strong>net cash proceeds from
        the sale of the house</strong> after the mortgage and conveyance
        costs are settled, approximately <strong>NZ$600,000</strong> at
        today's valuation and mortgage balance. Taxes and fees on the
        winner. If two people somehow both go 104-for-104, the proceeds
        split.
      </p>
      <p>
        Tournamental is run by <strong>Growth Spurt Ltd</strong>, Auckland.
      </p>

      <p class="vt-bet-signoff">
        See you on the leaderboard.
      </p>
      <p class="vt-bet-byline">
        <strong>Tim Thomas</strong>, Tournamental<br />
        <a href="mailto:info@tournamental.com">info@tournamental.com</a>
      </p>

      <div class="vt-bet-cta-row">
        <a class="vt-bet-cta-primary" href="https://play.tournamental.com/world-cup-2026">
          Pick your bracket →
        </a>
        <a class="vt-bet-cta-ghost" href="/odds">
          Show me the maths
        </a>
      </div>
    </section>
  </article>
</Layout>

<style>
  .vt-bet-body {
    max-width: 36rem;
    margin: 0 auto;
    padding-bottom: clamp(3rem, 7vw, 6rem);
    font-family: "Inter", system-ui, sans-serif;
    color: var(--vt-fg, #e7ecf7);
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .vt-bet-body p {
    margin: 0 0 1.25rem;
  }
  .vt-bet-lead {
    font-size: 1.1875rem;
  }
  .vt-bet-h2 {
    font-family: "Fraunces", ui-serif, Georgia, serif;
    font-weight: 500;
    font-variation-settings: "opsz" 80, "SOFT" 30;
    font-size: clamp(1.5rem, 3vw, 2rem);
    letter-spacing: -0.01em;
    line-height: 1.15;
    color: var(--vt-fg-strong, #ffffff);
    margin: 2.5rem 0 1rem;
  }
  .vt-bet-body a {
    color: var(--vt-gold-400, #dca94b);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .vt-bet-body a:hover {
    text-decoration-thickness: 2px;
  }
  .vt-bet-body code {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
    font-size: 0.9rem;
    background: rgba(255, 255, 255, 0.06);
    padding: 1px 6px;
    border-radius: 4px;
    color: var(--vt-gold-soft, #f6c64f);
  }
  .vt-bet-body strong {
    color: var(--vt-fg-strong, #ffffff);
  }
  .vt-bet-callout {
    background: rgba(220, 169, 75, 0.07);
    border-left: 3px solid var(--vt-gold-400, #dca94b);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    margin: 1.75rem 0 2rem;
  }
  .vt-bet-callout p {
    margin: 0 0 0.75rem;
  }
  .vt-bet-callout p:last-child {
    margin: 0;
  }
  .vt-bet-callout-head {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    color: var(--vt-gold-400, #dca94b);
    margin: 0 0 0.5rem !important;
  }
  .vt-bet-steps {
    margin: 0 0 1.5rem;
    padding: 0 0 0 1.25rem;
    counter-reset: bet-step;
    list-style: none;
  }
  .vt-bet-steps > li {
    position: relative;
    margin: 0 0 1rem;
    padding-left: 1.75rem;
    counter-increment: bet-step;
  }
  .vt-bet-steps > li::before {
    content: counter(bet-step);
    position: absolute;
    left: 0;
    top: 0;
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
    font-size: 0.85rem;
    color: var(--vt-gold-400, #dca94b);
    font-weight: 600;
  }
  .vt-bet-signoff {
    font-family: "Fraunces", ui-serif, Georgia, serif;
    font-style: italic;
    font-size: 1.25rem;
    color: var(--vt-fg-strong, #ffffff);
    margin-top: 2.5rem !important;
  }
  .vt-bet-byline {
    color: rgba(199, 208, 230, 0.85);
    margin-bottom: 2.5rem !important;
  }
  .vt-bet-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.5rem;
  }
  .vt-bet-cta-primary,
  .vt-bet-cta-ghost {
    display: inline-block;
    padding: 0.875rem 1.5rem;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none !important;
    transition: transform 100ms ease, background 100ms ease;
  }
  .vt-bet-cta-primary {
    background: var(--vt-gold-400, #dca94b);
    color: #15151a;
  }
  .vt-bet-cta-primary:hover {
    transform: translateY(-1px);
  }
  .vt-bet-cta-ghost {
    background: transparent;
    color: var(--vt-fg, #e7ecf7) !important;
    border: 1px solid rgba(255, 255, 255, 0.18);
  }
  .vt-bet-cta-ghost:hover {
    background: rgba(255, 255, 255, 0.05);
  }
</style>
