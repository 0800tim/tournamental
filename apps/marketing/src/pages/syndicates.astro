---
import Layout from "@/layouts/Layout.astro";
import SectionHeading from "@/components/SectionHeading.astro";

/**
 * /syndicates — light-touch landing.
 *
 * The full syndicate marketing surface (use-cases, pricing, embed
 * snippet, the playbook) lives on play.tournamental.com where the
 * dashboard and creation flow also live. This page is a single-screen
 * primer that explains what a syndicate is and CTAs people to the
 * play app for the rich experience.
 */
---
<Layout
  title="Run your own pool · Tournamental syndicates"
  description="Anyone can host a branded tournament prediction pool on Tournamental. Free embed widget for any site, premium tier adds a fully-managed CRM. Create yours on play.tournamental.com."
  ogImage="/og/syndicates.png"
>
  <section class="container-page pt-16 pb-12">
    <SectionHeading
      eyebrow="Syndicates"
      title="Run your own pool. Brand it your way."
      lede="A syndicate is your own branded prediction pool, hosted on Tournamental. Drop the embed widget on any site. Free forever; premium adds a fully-managed CRM. Create yours and read the full playbook on the play app."
    />
    <div class="flex flex-wrap gap-3">
      <a href="https://play.tournamental.com/syndicates/new" class="btn-primary">Create your World Cup syndicate →</a>
      <a href="https://play.tournamental.com/syndicates/playbook" class="btn-ghost">Read the playbook</a>
    </div>
  </section>

  <section class="container-page pb-16">
    <div class="grid md:grid-cols-3 gap-6">
      <div class="card">
        <h3 class="text-lg font-bold text-white">What it is</h3>
        <p class="text-ink-200 mt-2 text-sm">Your own branded pool for any tournament. Office, friends, fan club, store, school, radio station, creator audience. Same toolkit, your brand on every leaderboard.</p>
      </div>
      <div class="card">
        <h3 class="text-lg font-bold text-white">Free forever</h3>
        <p class="text-ink-200 mt-2 text-sm">Branded embed widget you drop on any site (Squarespace, WordPress, Shopify, custom). Members sign up on your site, picks-saved climbs in your storefront, share cards carry your brand.</p>
      </div>
      <div class="card">
        <h3 class="text-lg font-bold text-white">Premium tier</h3>
        <p class="text-ink-200 mt-2 text-sm">$97/month via <a href="/partners/aiva" class="link">Aiva</a> adds a fully-managed HighLevel CRM sub-account, your own SMS / WhatsApp / email, paid entries via Stripe (funds settle to your bank), and subdomain hosting.</p>
      </div>
    </div>
    <p class="text-ink-300 text-sm mt-8 max-w-2xl">
      The full freemium pitch, six audience-archetype scenarios, prize-structure templates, sponsor-pitch email templates, and a six-week run-of-show all live in the play app at{" "}
      <a href="https://play.tournamental.com/syndicates" class="link">play.tournamental.com/syndicates</a>{" "}
      alongside the creation form and the affiliate dashboard.
    </p>
  </section>
</Layout>
