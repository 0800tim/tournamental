---
/**
 * /sign-in — legacy URL, now redirects to play.tournamental.com.
 *
 * The marketing site does not authenticate users; sign-in lives on
 * the play surface. Anything that links to /sign-in here is bounced
 * to play.tournamental.com with the same query string preserved so
 * deep-links (e.g. `?next=/world-cup-2026`) still land where the
 * user expected.
 */
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Sign in · Tournamental</title>
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content="0; url=https://play.tournamental.com/" />
    <link rel="canonical" href="https://play.tournamental.com/" />
  </head>
  <body>
    <script is:inline>
      (function () {
        try {
          var search = window.location.search || "";
          var hash = window.location.hash || "";
          window.location.replace("https://play.tournamental.com/" + search + hash);
        } catch (e) {
          window.location.href = "https://play.tournamental.com/";
        }
      })();
    </script>
    <noscript>
      <p>Sign in has moved. <a href="https://play.tournamental.com/">Open the Tournamental play app</a>.</p>
    </noscript>
  </body>
</html>
