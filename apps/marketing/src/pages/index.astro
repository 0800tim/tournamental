---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import TournamentBook from "@/components/TournamentBook.astro";
---
<Layout ogImage="/og/index.png">
  <Hero />

  <TournamentBook />

  <!-- Syndicates — the creator pitch -->
  <section class="container-page py-12">
    <SectionHeading
      eyebrow="Syndicates"
      title="Run your own pool. play.tournamental.com/s/yourname"
      lede="Give your audience, office, or fan group their own branded prediction pool. Free embed widget for any site. Your logo, your leaderboard, your rules. Create yours and it goes live in minutes."
    />
    <div class="grid md:grid-cols-2 gap-6 mt-8">
      <div class="card">
        <h3 class="text-lg font-bold text-white">For creators and influencers</h3>
        <p class="text-ink-200 mt-2">Give your audience a syndicate page at your own URL slug. Every pick, every share card, every leaderboard update carries your brand. You drive traffic; we run the game; Drips Network pays you automatically in ETH.</p>
      </div>
      <div class="card">
        <h3 class="text-lg font-bold text-white">For offices and fan groups</h3>
        <p class="text-ink-200 mt-2">Office sweepstake or 5,000-person fan club, same toolkit. Custom leaderboard, group invite via WhatsApp or Telegram, settlement clip when the winner is declared. Handle money offline however you like.</p>
      </div>
      <div class="card">
        <h3 class="text-lg font-bold text-white">Branded share cards</h3>
        <p class="text-ink-200 mt-2">Every prediction generates a shareable image. Every leaderboard moment earns a clip. Members share to social and your syndicate grows. Network effects built in.</p>
      </div>
      <div class="card">
        <h3 class="text-lg font-bold text-white">Premium CRM via <a href="https://growthspurt.agency" target="_blank" rel="noopener" class="link">Growth Spurt</a></h3>
        <p class="text-ink-200 mt-2">$97/month adds a fully-managed HighLevel sub-account: your own SMS, WhatsApp, email, Stripe-backed paid entries, and subdomain hosting. Drips revenue share for hosts who bring real volume.</p>
      </div>
    </div>
    <div class="mt-8 flex gap-3">
      <a href="https://play.tournamental.com/syndicates/new" class="btn-primary" data-analytics="cta" data-analytics-label="Start a syndicate" data-analytics-surface="syndicates-section">Start a syndicate</a>
      <a href="/influencers" class="btn-ghost" data-analytics="cta" data-analytics-label="For influencers" data-analytics-surface="syndicates-section">For influencers</a>
    </div>
  </section>

  <!-- How the game works — three pillars -->
  <section class="container-page py-12">
    <SectionHeading
      eyebrow="How it works"
      title="Predict. Compete. Share."
      lede="The game is simple. The competition is global. Sign in, make your calls, and climb."
    />
    <div class="grid-cards mt-8">
      <article class="card">
        <div class="text-accent-400 font-mono text-sm">01</div>
        <h3 class="text-xl font-bold text-white mt-2">Predict</h3>
        <p class="text-ink-200 mt-3">Pick winners, scorers, scorelines, and special markets. Save any time, change any call until kickoff. Your Prediction IQ score is tracked for life, scored against the closing line so it's impossible to game.</p>
      </article>
      <article class="card">
        <div class="text-accent-400 font-mono text-sm">02</div>
        <h3 class="text-xl font-bold text-white mt-2">Compete</h3>
        <p class="text-ink-200 mt-3">Global, country, syndicate, and friend-group leaderboards update live as matches settle. Streak multipliers, underdog bonuses, and a Brier-score Prediction IQ that follows you across tournaments.</p>
      </article>
      <article class="card">
        <div class="text-accent-400 font-mono text-sm">03</div>
        <h3 class="text-xl font-bold text-white mt-2">Share</h3>
        <p class="text-ink-200 mt-3">Earn shareable goal clips, leaderboard cards, and position badges. Referrals turn into bonus tokens. Your syndicate grows every time a member shares a win.</p>
      </article>
    </div>
    <div class="mt-6 text-center">
      <a href="/how-it-works" class="link text-sm">Full rules and scoring explained →</a>
    </div>
  </section>

  <!-- Open source banner -->
  <section class="container-page py-12">
    <div class="card border-accent-700/60 bg-gradient-to-br from-ink-800 to-ink-900">
      <div class="grid md:grid-cols-3 gap-6 items-center">
        <div class="md:col-span-2">
          <span class="pill mb-3">Open source</span>
          <h3 class="text-2xl font-bold text-white">Apache 2.0. Contributors share platform revenue.</h3>
          <p class="text-ink-200 mt-3 max-w-prose">Every line of code, every doc, every spec is on GitHub. Build your own predictions product on top, fork the renderer, ship a tournament integration. Merged contributors opt in to a continuous USDC revenue share via the Drips Network.</p>
        </div>
        <div class="flex md:flex-col gap-3">
          <a href="https://github.com/0800tim/tournamental" class="btn-primary" data-analytics="cta" data-analytics-label="View the repo" data-analytics-surface="open-source-section">View the repo</a>
          <a href="/contribute" class="btn-ghost" data-analytics="cta" data-analytics-label="How to contribute" data-analytics-surface="open-source-section">How to contribute</a>
        </div>
      </div>
    </div>
  </section>

  <!-- World Cup CTA -->
  <section class="container-page py-12 mb-20">
    <div class="rounded-2xl border border-accent-700/60 bg-accent-700/10 p-8 md:p-12 grid md:grid-cols-3 gap-8 items-center">
      <div class="md:col-span-2">
        <span class="pill vt-pill-pulse mb-3">
          <span class="vt-icon-mask vt-icon-trophy size-3.5" aria-hidden="true"></span>
          Coming June 11, 2026
        </span>
        <h3 class="text-3xl md:text-4xl font-bold text-white tracking-tight">Set up your syndicate now. Be ready when the first whistle blows.</h3>
        <p class="mt-4 text-ink-200">Six weeks. 48 teams. 104 matches. One global leaderboard. The creator, the office, or the fan group that calls the most right will be a legend.</p>
      </div>
      <div class="flex md:flex-col gap-3">
        <a href="/world-cup-2026" class="btn-primary" data-analytics="cta" data-analytics-label="World Cup playbook" data-analytics-surface="wc2026-section">World Cup playbook</a>
        <a href="https://play.tournamental.com/syndicates/new" class="btn-ghost" data-analytics="cta" data-analytics-label="Start your syndicate" data-analytics-surface="wc2026-section">Start your syndicate</a>
      </div>
    </div>
  </section>
</Layout>
