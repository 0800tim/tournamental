---
/**
 * Site header.
 *
 * Desktop: 4 top-level items + an "About" dropdown that holds the
 * less-frequently-visited links (News, Blog, Open source, GitHub,
 * Contribute, For influencers, Legal). Theme toggle + Play CTA on
 * the right. Keeps the bar uncluttered.
 *
 * Mobile: a single hamburger button opens a fullscreen overlay with
 * the same items in a stack. About becomes an accordion-style group.
 * Drawer dismisses on close button, link click, Escape, or outside tap.
 */

const primaryLinks = [
  { href: "/why", label: "Why" },
  { href: "/how-it-works", label: "How it works" },
  { href: "/world-cup-2026", label: "World Cup 2026" },
];

const aboutLinks = [
  { href: "/syndicates", label: "Syndicates" },
  { href: "/leaderboards", label: "Leaderboards" },
  { href: "/news", label: "News" },
  { href: "/blog", label: "Blog" },
  { href: "/open-source", label: "Open source" },
  { href: "https://github.com/0800tim/tournamental", label: "GitHub", external: true },
  { href: "/contribute", label: "Contribute" },
  { href: "/influencers", label: "For influencers" },
  { href: "/legal", label: "Legal & privacy" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const aboutActive = aboutLinks.some((l) => !l.external && currentPath === l.href);
---
<header class="vt-header sticky top-0 z-40 border-b backdrop-blur">
  <div class="container-page flex items-center justify-between py-4">
    <a href="/" class="flex items-center gap-2 font-display text-xl font-bold tracking-tight">
      <span class="grid place-items-center size-7 rounded-md bg-accent-500 text-ink-900">
        <span class="vt-icon-mask vt-icon-v size-5" aria-hidden="true"></span>
      </span>
      <span class="vt-brand-name">Tournamental</span>
      <span class="hidden sm:inline pill">beta</span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm" aria-label="Primary">
      {primaryLinks.map((l) => (
        <a
          href={l.href}
          class:list={[
            "vt-nav-link",
            currentPath === l.href ? "is-active" : "",
          ]}
        >{l.label}</a>
      ))}
      <div class="vt-nav-dropdown" data-state="closed">
        <button
          type="button"
          class:list={["vt-nav-link vt-nav-dropdown-trigger", aboutActive ? "is-active" : ""]}
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="about-dropdown"
        >
          About
          <svg class="size-3" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
            <path d="M2 4l4 4 4-4z"/>
          </svg>
        </button>
        <div id="about-dropdown" class="vt-nav-dropdown-panel" role="menu">
          {aboutLinks.map((l) => (
            <a
              href={l.href}
              role="menuitem"
              class:list={[
                "vt-nav-dropdown-item",
                !l.external && currentPath === l.href ? "is-active" : "",
              ]}
              {...(l.external ? { rel: "me", target: "_blank" } : {})}
            >{l.label}</a>
          ))}
        </div>
      </div>
    </nav>

    <div class="flex items-center gap-2 md:gap-3">
      <button
        id="theme-toggle"
        type="button"
        class="vt-icon-btn"
        aria-label="Theme: system"
        title="Theme"
        data-theme-state="system"
      >
        <svg data-theme-icon="system" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="13" rx="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
        <svg data-theme-icon="light" class="size-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <svg data-theme-icon="dark" class="size-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <a
        href="https://2026wc.tournamental.com/"
        class="hidden md:inline-flex btn-primary vt-glow-cta text-sm"
      >Play World Cup 2026 →</a>

      <button
        id="mobile-menu-toggle"
        type="button"
        class="md:hidden vt-icon-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="mobile-menu-icon-open" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

{/* Mobile menu — fullscreen overlay outside <header> because the
    header's `backdrop-filter: blur` creates a containing block for
    `position: fixed` descendants. */}
<aside
  id="mobile-menu"
  class="vt-mobile-menu md:hidden"
  aria-label="Mobile navigation"
  aria-hidden="true"
  data-state="closed"
  role="dialog"
  aria-modal="true"
>
  <div class="vt-mobile-menu-bar">
    <span class="vt-mobile-menu-title">Menu</span>
    <button
      id="mobile-menu-close"
      type="button"
      class="vt-icon-btn vt-mobile-close"
      aria-label="Close menu"
    >
      <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <nav class="vt-mobile-menu-nav" aria-label="Primary mobile navigation">
    {primaryLinks.map((l) => (
      <a
        href={l.href}
        class:list={[
          "vt-mobile-link",
          currentPath === l.href ? "is-active" : "",
        ]}
      >{l.label}</a>
    ))}
    <details class="vt-mobile-accordion" open={aboutActive}>
      <summary class="vt-mobile-link vt-mobile-accordion-summary">
        About
        <svg class="vt-mobile-accordion-icon size-4" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
          <path d="M2 4l4 4 4-4z"/>
        </svg>
      </summary>
      <div class="vt-mobile-accordion-panel">
        {aboutLinks.map((l) => (
          <a
            href={l.href}
            class:list={[
              "vt-mobile-link vt-mobile-sublink",
              !l.external && currentPath === l.href ? "is-active" : "",
            ]}
            {...(l.external ? { rel: "me", target: "_blank" } : {})}
          >{l.label}</a>
        ))}
      </div>
    </details>
  </nav>
  <div class="vt-mobile-menu-foot">
    <button
      id="mobile-menu-theme"
      type="button"
      class="vt-mobile-link vt-mobile-theme-btn"
      aria-label="Toggle theme"
    >
      <span class="vt-mobile-theme-label">Theme: system</span>
      <span aria-hidden="true">↻</span>
    </button>
    <a
      href="https://2026wc.tournamental.com/"
      class="btn-primary vt-glow-cta vt-mobile-cta"
    >Play World Cup 2026 →</a>
  </div>
</aside>

<script is:inline>
  (function () {
    /* Mobile menu open/close */
    const toggle = document.getElementById("mobile-menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const closeBtn = document.getElementById("mobile-menu-close");

    function setOpen(open) {
      if (!menu || !toggle) return;
      menu.dataset.state = open ? "open" : "closed";
      menu.setAttribute("aria-hidden", open ? "false" : "true");
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
      toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      document.body.classList.toggle("vt-mobile-menu-open", open);
      if (open && closeBtn) closeBtn.focus();
      else if (toggle) toggle.focus();
    }

    if (toggle && menu) {
      toggle.addEventListener("click", () => setOpen(menu.dataset.state !== "open"));
      if (closeBtn) closeBtn.addEventListener("click", () => setOpen(false));
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && menu.dataset.state === "open") {
          e.preventDefault();
          setOpen(false);
        }
      });
      // Close when a link inside the overlay is followed (so the new page
      // appears, not the still-open overlay).
      menu.addEventListener("click", (e) => {
        const target = e.target;
        if (target instanceof HTMLAnchorElement && target.getAttribute("href")) {
          setOpen(false);
        }
      });
    }

    /* Desktop About dropdown */
    const dd = document.querySelector(".vt-nav-dropdown");
    if (dd) {
      const trigger = dd.querySelector(".vt-nav-dropdown-trigger");
      const panel = dd.querySelector(".vt-nav-dropdown-panel");
      function setDdOpen(open) {
        dd.dataset.state = open ? "open" : "closed";
        if (trigger) trigger.setAttribute("aria-expanded", open ? "true" : "false");
      }
      if (trigger && panel) {
        trigger.addEventListener("click", (e) => {
          e.preventDefault();
          e.stopPropagation();
          setDdOpen(dd.dataset.state !== "open");
        });
        // Click outside closes
        document.addEventListener("click", (e) => {
          if (dd.dataset.state === "open" && !dd.contains(e.target)) {
            setDdOpen(false);
          }
        });
        // Escape closes
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && dd.dataset.state === "open") {
            setDdOpen(false);
          }
        });
        // Click on a menu item closes (after navigation starts)
        panel.addEventListener("click", (e) => {
          if (e.target instanceof HTMLAnchorElement) setDdOpen(false);
        });
      }
    }

    /* Theme toggle: cycles system → light → dark → system */
    const KEY = "vtourn:theme";
    const STATES = ["system", "light", "dark"];
    const tBtn = document.getElementById("theme-toggle");
    if (tBtn) {
      const sysIcon = tBtn.querySelector('[data-theme-icon="system"]');
      const lightIcon = tBtn.querySelector('[data-theme-icon="light"]');
      const darkIcon = tBtn.querySelector('[data-theme-icon="dark"]');
      const drawerThemeBtn = document.getElementById("mobile-menu-theme");
      const drawerThemeLabel = drawerThemeBtn
        ? drawerThemeBtn.querySelector(".vt-mobile-theme-label")
        : null;
      const apply = (state) => {
        const resolved = state === "system"
          ? (window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark")
          : state;
        document.documentElement.setAttribute("data-theme", resolved);
        const mc = document.getElementById("vt-theme-color");
        if (mc) mc.setAttribute("content", resolved === "light" ? "#f5f7fc" : "#0a0e1a");
        tBtn.dataset.themeState = state;
        tBtn.setAttribute("aria-label", "Theme: " + state);
        if (sysIcon) sysIcon.classList.toggle("hidden", state !== "system");
        if (lightIcon) lightIcon.classList.toggle("hidden", state !== "light");
        if (darkIcon) darkIcon.classList.toggle("hidden", state !== "dark");
        if (drawerThemeLabel) drawerThemeLabel.textContent = "Theme: " + state;
      };
      const cycle = () => {
        const cur = tBtn.dataset.themeState ?? "system";
        const next = STATES[(STATES.indexOf(cur) + 1) % STATES.length];
        try { localStorage.setItem(KEY, next); } catch {}
        apply(next);
      };
      const stored = (() => { try { return localStorage.getItem(KEY); } catch { return null; } })();
      apply(stored && STATES.includes(stored) ? stored : "system");
      tBtn.addEventListener("click", cycle);
      if (drawerThemeBtn) {
        drawerThemeBtn.addEventListener("click", (e) => {
          e.preventDefault();
          e.stopPropagation();
          cycle();
        });
      }
      const mq = window.matchMedia("(prefers-color-scheme: light)");
      const onChange = () => {
        if ((tBtn.dataset.themeState ?? "system") === "system") apply("system");
      };
      if (mq.addEventListener) mq.addEventListener("change", onChange);
      else if (mq.addListener) mq.addListener(onChange);
    }
  })();
</script>
</content>
</invoke>