---
const links = [
  { href: "/why", label: "Why" },
  { href: "/how-it-works", label: "How it works" },
  { href: "/syndicates", label: "Syndicates" },
  { href: "/leaderboards", label: "Leaderboards" },
  { href: "/world-cup-2026", label: "World Cup 2026" },
  { href: "/news", label: "News" },
  { href: "/blog", label: "Blog" },
  { href: "/open-source", label: "Open source" },
];
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---
<header class="vt-header sticky top-0 z-40 border-b backdrop-blur">
  <div class="container-page flex items-center justify-between py-4">
    <a href="/" class="flex items-center gap-2 font-display text-xl font-bold tracking-tight">
      <span class="grid place-items-center size-7 rounded-md bg-accent-500 text-ink-900">
        <span class="vt-icon-mask vt-icon-v size-5" aria-hidden="true"></span>
      </span>
      <span class="vt-brand-name">VTourn</span>
      <span class="hidden sm:inline pill">beta</span>
    </a>
    <nav class="hidden md:flex items-center gap-6 text-sm">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            "vt-nav-link",
            currentPath === l.href ? "is-active" : "",
          ]}
        >{l.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-2 md:gap-3">
      <a href="https://github.com/0800tim/vtorn" class="hidden sm:inline link text-sm" rel="me">GitHub</a>

      <button
        id="theme-toggle"
        type="button"
        class="vt-icon-btn"
        aria-label="Theme: system"
        title="Theme"
        data-theme-state="system"
      >
        <svg data-theme-icon="system" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="13" rx="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
        <svg data-theme-icon="light" class="size-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <svg data-theme-icon="dark" class="size-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <a
        href="https://2026wc.vtourn.com/"
        class="hidden md:inline-flex btn-primary vt-glow-cta text-sm"
      >Play World Cup 2026 →</a>
      <a
        href="https://2026wc.vtourn.com/"
        class="md:hidden vt-icon-btn vt-icon-btn-primary"
        aria-label="Play World Cup 2026"
      >
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 9H4a2 2 0 0 1-2-2V5a1 1 0 0 1 1-1h3"/>
          <path d="M18 9h2a2 2 0 0 0 2-2V5a1 1 0 0 0-1-1h-3"/>
          <path d="M6 4h12v7a6 6 0 0 1-12 0z"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
        </svg>
      </a>
      <button
        id="mobile-menu-toggle"
        type="button"
        class="md:hidden vt-icon-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="mobile-menu-icon-open" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="mobile-menu-icon-close" class="size-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>
  {/* Mobile drawer + scrim. The drawer slides in from the right
      (full-height, ~85% width) when the hamburger toggle is tapped.
      Backdrop click + Escape + swipe-right gesture all dismiss it.
      Order: scrim sits behind the drawer; both are inside the header
      so they share the sticky positioning context. */}
  <div
    id="mobile-menu-scrim"
    class="vt-mobile-scrim md:hidden"
    aria-hidden="true"
    data-state="closed"
  ></div>
  <aside
    id="mobile-menu"
    class="vt-mobile-drawer md:hidden"
    aria-label="Mobile navigation drawer"
    aria-hidden="true"
    data-state="closed"
    role="dialog"
    aria-modal="false"
  >
    <div class="vt-mobile-drawer-inner">
      <header class="vt-mobile-drawer-head">
        <span class="font-display text-lg font-bold">Menu</span>
        <button
          id="mobile-menu-close"
          type="button"
          class="vt-icon-btn"
          aria-label="Close menu"
        >
          <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </header>
      <nav class="vt-mobile-drawer-nav" aria-label="Primary mobile navigation">
        {links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "vt-mobile-link",
              currentPath === l.href ? "is-active" : "",
            ]}
          >{l.label}</a>
        ))}
        <a href="https://github.com/0800tim/vtorn" class="vt-mobile-link" rel="me">GitHub</a>
        <a href="/contribute" class="vt-mobile-link">Contribute</a>
        <a href="/influencers" class="vt-mobile-link">For influencers</a>
        <a href="/legal" class="vt-mobile-link">Legal &amp; privacy</a>
      </nav>
      <div class="vt-mobile-drawer-foot">
        <button
          id="mobile-menu-theme"
          type="button"
          class="vt-mobile-link vt-mobile-theme-btn"
          aria-label="Toggle theme"
        >
          <span class="vt-mobile-theme-label">Theme: system</span>
          <span aria-hidden="true">↻</span>
        </button>
        <a
          href="https://2026wc.vtourn.com/"
          class="btn-primary vt-glow-cta vt-mobile-cta"
        >Play World Cup 2026 →</a>
      </div>
    </div>
  </aside>
</header>

<script is:inline>
  (function () {
    const toggle = document.getElementById("mobile-menu-toggle");
    const drawer = document.getElementById("mobile-menu");
    const scrim = document.getElementById("mobile-menu-scrim");
    const closeBtn = document.getElementById("mobile-menu-close");
    const iconOpen = document.getElementById("mobile-menu-icon-open");
    const iconClose = document.getElementById("mobile-menu-icon-close");

    function setOpen(open) {
      if (!drawer || !scrim || !toggle) return;
      drawer.dataset.state = open ? "open" : "closed";
      scrim.dataset.state = open ? "open" : "closed";
      drawer.setAttribute("aria-hidden", open ? "false" : "true");
      scrim.setAttribute("aria-hidden", open ? "false" : "true");
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
      toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      if (iconOpen) iconOpen.classList.toggle("hidden", open);
      if (iconClose) iconClose.classList.toggle("hidden", !open);
      // Lock body scroll while the drawer is open.
      document.body.classList.toggle("vt-mobile-menu-open", open);
      if (open) {
        // Focus the close button so keyboard users can dismiss with Enter.
        if (closeBtn) closeBtn.focus();
      } else {
        if (toggle) toggle.focus();
      }
    }

    if (toggle && drawer && scrim) {
      toggle.addEventListener("click", () => {
        const open = drawer.dataset.state !== "open";
        setOpen(open);
      });
      scrim.addEventListener("click", () => setOpen(false));
      if (closeBtn) closeBtn.addEventListener("click", () => setOpen(false));
      // Escape closes the drawer.
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && drawer.dataset.state === "open") {
          e.preventDefault();
          setOpen(false);
        }
      });
      // Swipe-right to close. Track touchstart on the drawer itself; if
      // the user moves > 64 px to the right, dismiss. We bypass this on
      // wide screens (drawer is hidden via CSS anyway).
      let touchStartX = null;
      drawer.addEventListener("touchstart", (e) => {
        if (drawer.dataset.state !== "open") return;
        if (e.touches.length !== 1) return;
        touchStartX = e.touches[0].clientX;
      }, { passive: true });
      drawer.addEventListener("touchmove", (e) => {
        if (touchStartX == null) return;
        const dx = e.touches[0].clientX - touchStartX;
        if (dx > 64) {
          touchStartX = null;
          setOpen(false);
        }
      }, { passive: true });
      drawer.addEventListener("touchend", () => {
        touchStartX = null;
      }, { passive: true });
      // Close drawer when a link inside it is followed (so the page
      // transition shows the destination, not the open drawer).
      drawer.addEventListener("click", (e) => {
        const target = e.target;
        if (target instanceof HTMLAnchorElement && target.getAttribute("href")) {
          setOpen(false);
        }
      });
    }

    // Theme toggle: cycles system → light → dark → system. The applied
    // theme is computed from the user's choice and prefers-color-scheme,
    // then mirrored to <html data-theme="...">. The choice persists in
    // localStorage under "vtourn:theme". The pre-paint init script in
    // Layout.astro applies the theme before hydration to avoid a FOUC.
    const KEY = "vtourn:theme";
    const STATES = ["system", "light", "dark"];
    const tBtn = document.getElementById("theme-toggle");
    if (tBtn) {
      const sysIcon = tBtn.querySelector('[data-theme-icon="system"]');
      const lightIcon = tBtn.querySelector('[data-theme-icon="light"]');
      const darkIcon = tBtn.querySelector('[data-theme-icon="dark"]');
      const drawerThemeBtn = document.getElementById("mobile-menu-theme");
      const drawerThemeLabel = drawerThemeBtn
        ? drawerThemeBtn.querySelector(".vt-mobile-theme-label")
        : null;
      const apply = (state) => {
        const resolved = state === "system"
          ? (window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark")
          : state;
        document.documentElement.setAttribute("data-theme", resolved);
        const mc = document.getElementById("vt-theme-color");
        if (mc) mc.setAttribute("content", resolved === "light" ? "#f5f7fc" : "#0a0e1a");
        tBtn.dataset.themeState = state;
        tBtn.setAttribute("aria-label", "Theme: " + state);
        if (sysIcon) sysIcon.classList.toggle("hidden", state !== "system");
        if (lightIcon) lightIcon.classList.toggle("hidden", state !== "light");
        if (darkIcon) darkIcon.classList.toggle("hidden", state !== "dark");
        if (drawerThemeLabel) drawerThemeLabel.textContent = "Theme: " + state;
      };
      const cycle = () => {
        const cur = tBtn.dataset.themeState ?? "system";
        const next = STATES[(STATES.indexOf(cur) + 1) % STATES.length];
        try { localStorage.setItem(KEY, next); } catch {}
        apply(next);
      };
      const stored = (() => { try { return localStorage.getItem(KEY); } catch { return null; } })();
      apply(stored && STATES.includes(stored) ? stored : "system");
      tBtn.addEventListener("click", cycle);
      // The drawer copy of the theme button cycles the same state. We
      // listen separately so each button can be removed/re-added without
      // breaking the other.
      if (drawerThemeBtn) {
        drawerThemeBtn.addEventListener("click", (e) => {
          e.preventDefault();
          // Stop the drawer's "auto-close on link click" handler (this
          // is a button, not a link, but the drawer-level click handler
          // is link-only — guarding here is belt and braces).
          e.stopPropagation();
          cycle();
        });
      }
      // Re-resolve when the OS preference changes and the user is on "system".
      const mq = window.matchMedia("(prefers-color-scheme: light)");
      const onChange = () => {
        if ((tBtn.dataset.themeState ?? "system") === "system") apply("system");
      };
      if (mq.addEventListener) mq.addEventListener("change", onChange);
      else if (mq.addListener) mq.addListener(onChange);
    }
  })();
</script>
