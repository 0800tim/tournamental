---
/**
 * Homepage hero, editorial-sport rewrite.
 *
 * Treated as a section front of a Saturday football broadsheet on the
 * eve of a major tournament. Type carries the page: a Fraunces display
 * headline, an italic lede, a tabular stat row, a single confident CTA.
 * No product preview card, no parallax tilt, no competing accents.
 *
 * Lives under the `.vt-editorial` scope so it inherits the editorial
 * tokens defined in globals.css (gold accent, opsz axis, hairline rules,
 * choreographed first-paint reveal). All motion gates on
 * `prefers-reduced-motion` automatically via that scope.
 */
import StatLine from "@/components/StatLine.astro";

const KICKOFF_LABEL = "Kickoff 11 June 2026";
const HEADLINE_LINE_1 = "Can you call";
const HEADLINE_LINE_2 = "every match of";
const HEADLINE_LINE_3 = "the World Cup?";

const STATS = [
  { value: "104", label: "Matches" },
  { value: "48", label: "Teams" },
  { value: "0", label: "Perfect brackets" },
  { value: "∞", label: "Claim to glory" },
];

const startHref = "https://play.tournamental.com/syndicates/new";
const rulesHref = "/how-it-works";
---
<section class="vt-editorial vt-hero">
  <div class="container-page vt-hero-inner">
    <p class="vt-dateline" data-reveal="dateline">
      Tournamental &middot; World Cup 2026 &middot; {KICKOFF_LABEL}
    </p>

    <h1 class="vt-headline mt-7" data-reveal="headline">
      <span class="vt-hero-line">{HEADLINE_LINE_1}</span>
      <span class="vt-hero-line">
        every <em>match</em> of
      </span>
      <span class="vt-hero-line">{HEADLINE_LINE_3}</span>
    </h1>

    <hr class="vt-rule mt-10" data-reveal="rule" aria-hidden="true" />

    <p class="vt-lede mt-8" data-reveal="lede">
      <strong>Nobody has ever done it.</strong>
      Twenty-two World Cups, 964 matches, and the perfect bracket has
      stayed unclaimed. The 104 matches of 2026 are the next attempt.
      Tournamental keeps the global ledger and settles every pick on
      record, so the claim to glory is finally provable.
    </p>

    <div class="mt-12 md:mt-14" data-reveal="stats">
      <StatLine stats={STATS} />
    </div>

    <div class="vt-hero-cta-row mt-12 md:mt-16" data-reveal="cta">
      <a class="vt-cta-primary" href={startHref} data-analytics="cta" data-analytics-label="Start a pool" data-analytics-surface="hero">
        Start your pool <span aria-hidden="true">&rarr;</span>
      </a>
      <a class="vt-cta-text" href={rulesHref} data-analytics="cta" data-analytics-label="How scoring works" data-analytics-surface="hero">
        How scoring works
      </a>
    </div>

    <p class="vt-footnote mt-10" data-reveal="footnote">
      Free to play &middot; Apache 2.0 &middot; Contributors share platform revenue
    </p>
  </div>
</section>

<style>
  .vt-hero {
    /* The hero opts out of the page-level radial-gradient body wash so
     * the type sits on a flat canvas. The rest of the page keeps the
     * existing background glow; only this section drops it. */
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }
  .vt-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--vt-bg);
    z-index: -1;
  }

  .vt-hero-inner {
    padding-top: clamp(3rem, 7vw, 6rem);
    padding-bottom: clamp(3rem, 7vw, 6rem);
  }

  /* Stack the three headline lines so each rises individually. */
  .vt-hero-line {
    display: block;
  }

  .vt-hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem 2rem;
  }

  /* Slightly tighter stat row spacing on the hero specifically. */
  .vt-editorial .vt-stat-num {
    line-height: 0.95;
  }
</style>
