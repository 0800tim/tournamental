---
import "@/styles/globals.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /**
   * Optional explicit og:image dimensions; default to the standard 1200x630
   * card size produced by `@vtorn/social-cards`. Telegram and LinkedIn rely
   * on these to pick the preview at scale.
   */
  ogImageWidth?: number;
  ogImageHeight?: number;
}

const {
  title = "VTourn — predict the world's biggest matches with your friends",
  description = "Watch the FIFA World Cup, Six Nations, the Cricket World Cup and any other tournament play out in 3D, predict outcomes for points, run your own pool at yourname.vtourn.com, and climb a global leaderboard.",
  ogImage = "/og-default.png",
  ogImageWidth = 1200,
  ogImageHeight = 630,
} = Astro.props;

const canonicalUrl = Astro.url.href.replace(/\/$/, "");
const absoluteOgImage = ogImage.startsWith("http")
  ? ogImage
  : new URL(ogImage, Astro.site ?? "https://vtourn.com").toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="VTourn" />
    <meta property="og:locale" content="en_NZ" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:image:alt" content={title} />
    <meta name="twitter:site" content="@vtourn" />
    {/* Telegram link previews read og:* + twitter:image; the explicit tag below
        is honoured by Telegram's instant-view legacy spec. */}
    <meta name="telegram:channel" content="@vtourn" />
    <link rel="canonical" href={canonicalUrl} />
    <meta id="vt-theme-color" name="theme-color" content="#0a0e1a" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      // Apply the user's theme choice before first paint to avoid a
      // FOUC. State is one of "system" | "light" | "dark"; system
      // resolves to OS preference. Mirrors localStorage key
      // "vtourn:theme" — see Header.astro for the toggle UI.
      (function () {
        try {
          var raw = localStorage.getItem("vtourn:theme");
          var state = raw === "light" || raw === "dark" || raw === "system" ? raw : "system";
          var resolved = state === "system"
            ? (window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark")
            : state;
          document.documentElement.setAttribute("data-theme", resolved);
          var mc = document.getElementById("vt-theme-color");
          if (mc) mc.setAttribute("content", resolved === "light" ? "#f5f7fc" : "#0a0e1a");
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>
    {/* Critical light-mode overrides inlined in <head> so the browser
        applies them BEFORE the external globals.css module finishes
        loading. Without this, in dev mode the CSS module is async and
        text-white briefly paints white-on-white when the user is on
        light theme. Specificity (0,1,1) + !important beats any
        Tailwind utility that arrives later. */}
    <style is:inline>
      :root[data-theme="light"] { background-color: #f5f7fc; color: #0a0e1a; }
      :root[data-theme="light"] body { background-color: #f5f7fc; }
      :root[data-theme="light"] .text-white,
      :root[data-theme="light"] .text-ink-50,
      :root[data-theme="light"] .text-ink-100 { color: #0a0e1a !important; }
      :root[data-theme="light"] .text-ink-200 { color: #3e4a72 !important; }
      :root[data-theme="light"] .text-ink-500 { color: #5e6a8a !important; }
      :root[data-theme="light"] h1,
      :root[data-theme="light"] h2,
      :root[data-theme="light"] h3,
      :root[data-theme="light"] h4 { color: #0a0e1a !important; }
      :root[data-theme="light"] .bg-ink-900 { background-color: #f5f7fc !important; }
      :root[data-theme="light"] .bg-ink-800 { background-color: #ffffff !important; }
      :root[data-theme="light"] .bg-ink-700 { background-color: #e7ecf7 !important; }
      :root[data-theme="light"] .border-ink-700,
      :root[data-theme="light"] .border-ink-800,
      :root[data-theme="light"] .border-ink-600 { border-color: #cdd5e7 !important; }
      :root[data-theme="light"] strong { color: #0a0e1a; }
    </style>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
