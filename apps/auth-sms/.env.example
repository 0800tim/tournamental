# apps/auth-sms — example environment.
#
# Copy this file to `.env` and fill in real values. The `.env` itself
# is gitignored — never commit secrets.
#
# Two ways to get the long random values below:
#   openssl rand -hex 32           (64 hex chars, 32 bytes)
#   openssl rand -base64 32        (44 base64 chars, 32 bytes)

# ---------- runtime ----------
NODE_ENV=production
LOG_LEVEL=info
AUTH_PORT=3330
AUTH_BIND=0.0.0.0
# Pretty logs only in interactive dev; CI/prod use JSON.
AUTH_PRETTY_LOGS=false

# ---------- core secrets ----------
# HMAC secret used to hash OTPs at rest. Must be >= 32 chars.
AUTH_OTP_SECRET=CHANGE_ME_32_CHARS_MINIMUM_aaaaaaaaaaaaaaaaa
# HMAC secret used to sign session JWTs. Must be >= 32 chars.
AUTH_JWT_SECRET=CHANGE_ME_32_CHARS_MINIMUM_bbbbbbbbbbbbbbbbb
# Bearer token gating /v1/auth/whatsapp/pairing-qr (admin only).
AUTH_ADMIN_TOKEN=CHANGE_ME_admin_bearer_token

# ---------- product config ----------
AUTH_APP_HOST=tournamental.com
AUTH_PRODUCT_NAME=Tournamental
AUTH_CORS_ORIGINS=https://tournamental.com,https://play.tournamental.com,https://auth.tournamental.com
AUTH_DB_PATH=./data/auth.db
AUTH_OTP_TTL_SECONDS=600
AUTH_MAX_VERIFY_ATTEMPTS=5
AUTH_SESSION_TTL_SECONDS=2592000

# ---------- Aiva SMS gateway (outbound /v1/auth/request flow) ----------
# Tournamental sends OTPs by HTTP-POSTing to an Aiva SMS endpoint.
# See https://aiva.nz for the Aiva SMS platform.
AIVA_SMS_URL=https://your-aiva-host.example/api/sms/send
AIVA_SMS_API_KEY=CHANGE_ME_aiva_api_key

# ---------- WhatsApp transport ----------
# `aiva` routes WhatsApp messages through the same Aiva gateway.
# `baileys` runs an in-process Baileys session (requires QR pairing).
WHATSAPP_TRANSPORT=aiva
BAILEYS_AUTH_DIR=./baileys-auth
BAILEYS_QR_PATH=./baileys-auth/last-qr.png

# ---------- Telegram Login Widget (optional, recommended) ----------
# Get a bot token from @BotFather on Telegram (Bot Father).
#   /newbot                  -> picks a name + username
#   /setdomain               -> set to your apex domain so the Login
#                               Widget only renders on tournamental.com
#
# The bot token is the HMAC key Telegram signs Login Widget payloads
# with; auth-sms verifies that signature locally and mints a session.
# Zero dependency on any external SMS or gateway provider.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=TournamentalGamesBot

# ---------- Inbound-login flow ----------
# The Aiva gateway POSTs to /v1/auth/inbound-login with this header
# value in `x-inbound-secret`. MUST be high-entropy random; rotate via
# this file and a service restart. Empty value disables the endpoint
# (returns 401 on every call).
INBOUND_LOGIN_SECRET=CHANGE_ME_openssl_rand_hex_32

# Per-code attempt cap before the OTP row is burned. Primary
# brute-force defence on magic-verify + verify-by-code.
INBOUND_MAGIC_MAX_ATTEMPTS=5

# Per-IP cap on verify-by-code attempts that match NO active OTP
# (the blind-guessing pattern). Successful + matched-but-wrong
# verifies do NOT count against this bucket — only no-match
# attempts do. Generous on purpose so a shared office NAT (20+
# people behind one public IP) can all sign in within a few minutes
# of each other without tripping it.
INBOUND_CODE_IP_FAILURE_MAX=60

# Cookie domain for the inbound-flow session cookie. Apex with a
# leading dot so it's sent on both tournamental.com (marketing) and
# play.tournamental.com (web app).
INBOUND_COOKIE_DOMAIN=.tournamental.com

# ---------- HighLevel (GoHighLevel) CRM contact sync ----------
# Every registered user is mirrored into HighLevel as a contact tagged
# `player` the moment we learn their phone (first sign-in) or email, and
# re-synced when they edit their profile. Best-effort and non-blocking:
# a missing/incorrect key never blocks login (the sync is skipped/logged).
#
# Use the SUB-ACCOUNT (location) private-integration token — same
# sub-account as the web syndicate funnel (GHL_API_KEY / GHL_LOCATION_ID
# in apps/web). Leaving GHL_API_KEY empty disables the sync entirely.
GHL_API_KEY=
GHL_LOCATION_ID=
# Optional; defaults to https://services.leadconnectorhq.com when empty.
# Do NOT add a trailing slash.
GHL_API_BASE_URL=https://services.leadconnectorhq.com
