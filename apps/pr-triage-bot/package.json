{
  "name": "@vtorn/pr-triage-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous pull-request triage bot — classifies, risk-scores, comments, labels, and assigns reviewers.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "vtorn-triage": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prestart": "tsc -p tsconfig.json",
    "triage": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint: noop (typecheck covers it)'"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.1",
    "fastify": "^5.0.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  }
}
