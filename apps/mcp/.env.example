# apps/mcp — Tournamental MCP server.
# Copy to `.env` and fill in the real secrets, then `pm2 restart vtorn-mcp`.
# `.env` is gitignored; this `.env.example` is committed as the canonical
# shape of the prod config.
#
# Exposes Tournamental's read + write + admin tools to MCP-capable
# clients (Claude Desktop, Cursor, custom agents). Public read tools
# work without a key. Write tools require a personal user key. Admin
# tools require the master admin key AND an IP allowlist match.

# Port + bind. Docs/22 assigns the MCP server port 3395; mcp.tournamental.com
# routes to 127.0.0.1:3395 via the Cloudflare Tunnel ingress (see CF Zero
# Trust dashboard, Public Hostnames). Bind to localhost only — the tunnel
# is the only intended ingress.
MCP_PORT=3395
MCP_BIND=127.0.0.1

# Hosts allowed to call the JSON-RPC endpoint from a browser (CORS).
MCP_CORS_ORIGINS=https://play.tournamental.com,https://tournamental.com,http://localhost:3300

# JSONL audit log path. Process must have write permission.
MCP_AUDIT_PATH=/home/clawdbot/clawdia/projects/vtorn/apps/mcp/data/audit.jsonl

LOG_LEVEL=info
LOG_PRETTY=0

# Where to reach the game service for the underlying REST calls.
GAME_BASE_URL=http://localhost:3360

# Master admin key for admin/* MCP tools. Generate: openssl rand -hex 32
TOURNAMENTAL_ADMIN_KEY=

# Comma-separated CIDR allowlist for the admin key. Requests from
# outside these ranges get 403'd even with a valid admin key.
# Example: 127.0.0.1/32,10.0.0.0/8
TOURNAMENTAL_ADMIN_IPS=127.0.0.1/32

# Optional default user key for local/CLI usage. Production deployments
# leave this blank and require users to pass their own
# `tnm_live_<32-char-base62>` key on each request.
TOURNAMENTAL_USER_KEY=
