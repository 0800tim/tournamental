# Port the fan-out WS + admin REST listens on.
STREAM_PORT=4002

# Bind address. 0.0.0.0 for tunnel-fronted dev, 127.0.0.1 for local-only.
STREAM_BIND=0.0.0.0

# Comma-separated list of upstream producer WebSocket URLs to subscribe
# to. Each producer's MatchInit.match_id determines which ring it lands
# in. Defaults to the local statsbomb-replay producer.
STREAM_PRODUCER_URLS=ws://localhost:4001

# How many seconds of recent frames the ring keeps in memory per match.
# At 30Hz with ~3KB frames this is ~5MB per match per minute, so 60s is
# ~5MB resident — comfortable for any realistic match count.
STREAM_RING_SECONDS=60

# Bearer token required for /admin/* routes. Empty disables admin
# entirely (returns 503). Generate with `openssl rand -hex 32`.
STREAM_ADMIN_TOKEN=

# Per-IP and total subscriber connection caps. Single-node design.
STREAM_MAX_CONNS_PER_IP=100
STREAM_MAX_CONNS_TOTAL=5000

# Logging level: trace | debug | info | warn | error
LOG_LEVEL=info

# 1 to enable pino-pretty in dev. Off in production.
LOG_PRETTY=0
