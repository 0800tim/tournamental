{
  "name": "@vtorn/news-aggregator",
  "version": "0.0.1",
  "private": true,
  "description": "Tournamental news aggregator — polite RSS poller across 6 football news sources, normalises to a common shape, exposes a JSON API for the marketing site and bracket app.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prestart": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint: noop (typecheck covers it for this service)'"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "fastify": "^5.0.0",
    "pino": "^9.5.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "tsx": "^4.22.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
