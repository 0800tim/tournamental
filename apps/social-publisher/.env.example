# @vtorn/social-publisher — environment variables.
#
# Adapters that ship REAL API calls today: Discord, Telegram, Reddit, WhatsApp.
# Adapters that are stub-only (gated on App Review / paid tier): TikTok,
# Instagram Reels, YouTube Shorts, X (Twitter), Threads.
#
# Each adapter falls back to deterministic stub mode if its env vars or
# config file is missing/empty -- so an unconfigured deploy never crashes,
# it just no-ops on those channels and the audit log records the stub.
#
# Per-adapter mode is reported on `GET /healthz` (`adapter_modes` field).

# ---- Service ----
SOCIAL_PUBLISHER_PORT=3382
SOCIAL_PUBLISHER_BIND=0.0.0.0
SOCIAL_PUBLISHER_LOG_PATH=./data/posts.jsonl
LOG_LEVEL=info

# ---- Discord (REAL — src/lib/adapters/discord.ts) ----
# Webhook URLs are configured per-tournament in
# config/discord-webhooks.json (it's the secret -- treat the file as
# sensitive). The env vars below are operator-overrides.
SOCIAL_PUBLISHER_DISCORD_MODE=                  # set to `stub` to force stub mode
SOCIAL_PUBLISHER_DISCORD_CONFIG=                # override path to discord-webhooks.json

# ---- Telegram (REAL — src/lib/adapters/telegram.ts) ----
# Two routing modes:
#   1. Direct Bot API (default).        Set TELEGRAM_BOT_TOKEN.
#   2. Tournament-bot push proxy.       Set TOURNAMENT_BOT_PUSH_URL +
#                                       TOURNAMENT_BOT_PUSH_SECRET.
# Per-tournament chat list lives in config/telegram-targets.json.
TELEGRAM_BOT_TOKEN=
TOURNAMENT_BOT_PUSH_URL=
TOURNAMENT_BOT_PUSH_SECRET=
SOCIAL_PUBLISHER_TELEGRAM_MODE=                 # set to `stub` to force stub mode
SOCIAL_PUBLISHER_TELEGRAM_CONFIG=

# ---- Reddit (REAL — src/lib/adapters/reddit.ts) ----
# Script-app password grant. Create the app at
# https://www.reddit.com/prefs/apps (type: script). The client secret is
# rotated on the same page.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=vtorn-social-publisher/0.1
# Public base URL the clip MP4 is reachable at (for the link-post `url`
# field). E.g. https://clips.tournamental.com.
REDDIT_PUBLIC_CLIP_BASE=
SOCIAL_PUBLISHER_REDDIT_MODE=                   # set to `stub` to force stub mode
SOCIAL_PUBLISHER_REDDIT_CONFIG=

# ---- WhatsApp (REAL — src/lib/adapters/whatsapp.ts) ----
AIVA_SMS_API_URL=                               # gateway base URL (default http://localhost:9252)
AIVA_SMS_API_KEY=                               # bearer token for the gateway
AIVA_WA_SESSION_ID=                             # pre-paired Baileys session id
WHATSAPP_GROUP_IDS=                             # CSV of `<digits>@g.us`

# ---- TikTok (STUB — src/lib/adapters/tiktok.ts) ----
# Gated on TikTok Developer + Direct Post scope approval.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# ---- Instagram Reels (STUB — src/lib/adapters/instagram-reels.ts) ----
# Gated on Meta App Review (`instagram_content_publish`).
IG_GRAPH_TOKEN=
IG_USER_ID=
IG_APP_ID=
IG_APP_SECRET=

# ---- YouTube Shorts (STUB — src/lib/adapters/youtube-shorts.ts) ----
# Gated on Google OAuth verification (sensitive scopes).
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_OAUTH_REFRESH=
YT_CHANNEL_ID=

# ---- X / Twitter (STUB — src/lib/adapters/x.ts) ----
# Gated on paid X API tier ($200/mo Basic minimum).
X_CLIENT_ID=
X_CLIENT_SECRET=
X_ACCESS_TOKEN=
X_OAUTH1_KEY=
X_OAUTH1_SECRET=

# ---- Threads (STUB — src/lib/adapters/threads.ts) ----
# Gated on Meta App Review (`threads_content_publish`).
THREADS_GRAPH_TOKEN=
THREADS_USER_ID=
THREADS_APP_ID=
THREADS_APP_SECRET=
