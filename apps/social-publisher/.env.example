# @vtorn/social-publisher — environment variables.
#
# v0.1: only the service env vars are required (none, really — the defaults
# are sane for dev). The platform secrets below are listed so the next agent
# knows what to provision when wiring real API calls behind each adapter
# stub. None of them are read in v0.1.

# ---- Service ----
SOCIAL_PUBLISHER_PORT=3382
SOCIAL_PUBLISHER_BIND=0.0.0.0
SOCIAL_PUBLISHER_LOG_PATH=./data/posts.jsonl
LOG_LEVEL=info

# ---- TikTok (src/lib/adapters/tiktok.ts) ----
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# ---- Instagram Reels (src/lib/adapters/instagram-reels.ts) ----
IG_GRAPH_TOKEN=
IG_USER_ID=
IG_APP_ID=
IG_APP_SECRET=

# ---- YouTube Shorts (src/lib/adapters/youtube-shorts.ts) ----
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_OAUTH_REFRESH=
YT_CHANNEL_ID=

# ---- X / Twitter (src/lib/adapters/x.ts) ----
X_CLIENT_ID=
X_CLIENT_SECRET=
X_ACCESS_TOKEN=
X_OAUTH1_KEY=
X_OAUTH1_SECRET=

# ---- Threads (src/lib/adapters/threads.ts) ----
THREADS_GRAPH_TOKEN=
THREADS_USER_ID=
THREADS_APP_ID=
THREADS_APP_SECRET=

# ---- Telegram (src/lib/adapters/telegram.ts) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_BRAND_CHANNEL_ID=

# ---- Discord (src/lib/adapters/discord.ts) ----
DISCORD_BRAND_WEBHOOK_URL=

# ---- Reddit (src/lib/adapters/reddit.ts) ----
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=vtorn-social-publisher/0.1
