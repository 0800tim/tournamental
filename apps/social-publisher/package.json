{
  "name": "@vtorn/social-publisher",
  "version": "0.0.1",
  "private": true,
  "description": "Multi-platform fan-out for Tournamental match clips and bracket cards (TikTok, Instagram Reels, YouTube Shorts, X, Threads, Telegram, Discord, Reddit)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prestart": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "dump-openapi": "tsx scripts/dump-openapi.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "fastify": "^5.1.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "tsx": "^4.22.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
