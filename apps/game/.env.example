# Game service — port + bind. See docs/22.
GAME_PORT=3360
GAME_BIND=0.0.0.0

# SQLite database path. Relative paths resolve from process.cwd().
GAME_DB_PATH=./apps/game/data/game.db

# Bearer token required for admin-only routes (POST /v1/match/:id/result).
# Leave blank locally for tests; set a real secret in dev/staging/prod env.
GAME_ADMIN_TOKEN=

# Optional: leaderboard cache TTL in seconds (default 30).
GAME_LEADERBOARD_TTL_S=30

# Optional: comma-separated CORS origins for browser clients.
GAME_CORS_ORIGINS=https://vtorn.aiva.nz,http://localhost:3300

# Optional: pino log level (default info).
LOG_LEVEL=info
