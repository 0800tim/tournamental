{
  "name": "@vtorn/dm-poll-forwarder",
  "version": "0.1.0",
  "private": true,
  "description": "Polling worker that forwards Reddit/Mastodon/Signal DMs into the dm-otp ingest endpoint (those three platforms have no native webhooks)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prestart": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'no lint configured'",
    "dump-openapi": "tsx scripts/dump-openapi.ts"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "fastify": "^5.0.0",
    "pino": "^9.5.0",
    "undici": "^7.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  }
}
