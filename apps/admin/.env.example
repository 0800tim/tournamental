# Tournamental Admin Dashboard env

# Phone (E.164) that receives the step-up WhatsApp OTP. Hardcoded
# server-side so an attacker who clears Cloudflare Access still can't
# route OTPs to a number they control. If unset, login is disabled.
# CHANGE_ME: set to the operator's E.164 phone (e.g. +64XXXXXXXXXX).
ADMIN_PHONE_E164=+64XXXXXXXXXX

# Comma-separated allowlist of auth-sms user ids that may sign in to
# the admin console. The /v1/auth/verify response is checked against
# this list before the admin_session cookie is set. If unset or empty,
# login is disabled.
# Example: ADMIN_ALLOWED_USER_IDS=u_be5a445cff4347f6ae6089
ADMIN_ALLOWED_USER_IDS=

# 32+ char random secret for signing admin_session JWTs. Different from
# the auth-sms AUTH_JWT_SECRET on purpose: admin is a separate authority
# domain. Generate: openssl rand -base64 48
ADMIN_JWT_SECRET=

# 32+ char random secret used to sign admin-minted *manage* JWTs
# (impersonation tokens for play.tournamental.com/manage/syndicates/<slug>).
# MUST be different from both ADMIN_JWT_SECRET and the auth-sms
# AUTH_JWT_SECRET so that a compromised admin surface cannot forge
# user `tnm_session` cookies. The web app's verifyManageToken accepts
# both this secret and AUTH_JWT_SECRET during the rotation window.
# Generate: openssl rand -base64 48
# CHANGE_ME
ADMIN_MANAGE_JWT_SECRET=

# Auth-sms public origin. Defaults to prod when unset; point at the dev
# auth-sms (e.g. http://localhost:8786) when iterating locally.
ADMIN_AUTH_SMS_BASE_URL=https://auth.tournamental.com

# Upstream API for /v1/admin/* calls. The admin app is a thin BFF, but
# the canonical surface lives on apps/api. When unset, the admin app
# falls back to deterministic mock data so the UI still works during
# initial bring-up.
VTORN_API_BASE=http://localhost:3310

# Optional: set to "1" to force mock-data fallback even when VTORN_API_BASE
# is reachable. Useful for design + RTL test iteration.
ADMIN_USE_MOCKS=
