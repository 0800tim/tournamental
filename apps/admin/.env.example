# Tournamental Admin Dashboard env

# Comma-separated allowlist of admin email addresses. If unset or empty the
# magic-link issuer refuses to send and login is disabled.
# Example: ADMIN_EMAILS=tim@tournamental.com,ops@tournamental.com
ADMIN_EMAILS=

# 32+ char random secret for signing admin session JWTs.
# Generate: openssl rand -base64 48
ADMIN_JWT_SECRET=

# Magic-link mailer. One of: log | resend | mailgun
# - "log" prints the link to stderr (dev only).
# - "resend" uses RESEND_API_KEY.
# - "mailgun" uses MAILGUN_API_KEY + MAILGUN_DOMAIN.
ADMIN_MAILER=log
RESEND_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
ADMIN_MAIL_FROM="Tournamental Admin <admin@tournamental.com>"

# RBAC override map. Default role is "viewer" if not listed.
# Format: email:role pairs, comma-separated. role in {super-admin, mod, viewer}.
# Example: ADMIN_ROLES=tim@tournamental.com:super-admin,mod@tournamental.com:mod
ADMIN_ROLES=

# Base URL the magic-link should send users back to.
ADMIN_BASE_URL=http://localhost:3340

# Upstream API for /v1/admin/* calls. The admin app is a thin BFF, but the
# canonical surface lives on apps/api.
VTORN_API_BASE=http://localhost:3310
