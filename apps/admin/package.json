{
  "name": "@vtorn/admin",
  "version": "0.0.1",
  "private": true,
  "description": "Tournamental internal admin dashboard (Next.js 14)",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3340",
    "build": "NODE_ENV=production next build",
    "start": "next start -p 3340",
    "lint": "next lint --dir app --dir components --dir lib --dir __tests__",
