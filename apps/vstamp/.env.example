# VStamp service configuration. Copy to .env and fill in.
# See README.md and docs/17-vstamp-and-prediction-iq.md for protocol detail.

# Listening
VSTAMP_PORT=3390
VSTAMP_BIND=0.0.0.0

# SQLite database file (created if missing). Path is relative to repo root by default.
VSTAMP_DB_PATH=./apps/vstamp/data/vstamp.db

# Admin token guarding POST /v1/vstamp/finalise/:tournament_id.
# Generate with `openssl rand -hex 32`. Compared in constant time.
VSTAMP_ADMIN_TOKEN=

# Passphrase that encrypts the Ed25519 signing private key at rest (AES-256-GCM).
# This must be the same across restarts; if lost, existing roots can still be
# verified against their stored pubkey but no further roots can be signed by
# the same key. Generate with `openssl rand -hex 32`.
VSTAMP_KEY_PASSPHRASE=

# CORS allowlist for browser-based verifier clients (comma-separated).
VSTAMP_CORS_ORIGINS=https://play.tournamental.com,http://localhost:3300

# Logging. `info` in prod, `debug` while developing. Set LOG_PRETTY=1 for pino-pretty in dev.
LOG_LEVEL=info
LOG_PRETTY=0
