{
  "name": "@vtorn/mock-producer",
  "version": "0.0.0",
  "private": true,
  "description": "Tournamental synthetic match generator (renderer dev fixture)",
  "type": "module",
  "bin": {
    "mock-producer": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json && node dist/cli.js",
    "start": "node dist/cli.js",
    "prestart": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tournamental/spec": "workspace:*",
    "commander": "^12.1.0",
    "seedrandom": "^3.0.5",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/seedrandom": "^3.0.8",
    "@types/ws": "^8.5.13",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
