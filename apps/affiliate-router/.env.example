# =============================================================================
# @vtorn/affiliate-router — environment template
#
# Copy to `.env` and fill in real values per environment. NEVER commit `.env`.
# Real affiliate codes live in the deployment secret store; this file holds
# only placeholders so a fresh checkout boots cleanly in dev.
# =============================================================================

# --- service ---
AFFILIATE_PORT=3370
AFFILIATE_BIND=0.0.0.0

# Path to the SQLite click log. ":memory:" is for tests only.
AFFILIATE_DB_PATH=./data/clicks.db

# Override the partners.json path if running multiple deployments off one tree.
# AFFILIATE_PARTNERS_PATH=./data/partners.json

# CSV of allowed origins. Add the prod marketing + bracket hosts here.
AFFILIATE_CORS_ORIGINS=https://vtourn.com,https://app.vtourn.com,https://2026wc.vtourn.com,https://vtorn.aiva.nz,https://vtorn-aff.aiva.nz,http://localhost:3300

# Per-IP rate limit (clicks per minute).
AFFILIATE_RATE_LIMIT_MAX=30

# --- privacy ---
# Salt for hashing user_id before persistence. Required in production.
# Must be at least 16 chars; 32+ random bytes recommended.
# Rotating this invalidates the per-(user, partner) 24h dedupe — only do that
# intentionally.
AFFILIATE_USER_HASH_SALT=change-me-please-this-must-be-32-random-bytes

# --- partner affiliate codes ---
# Each entry overrides the placeholder in data/partners.json.
# Get these from each partner's affiliate console.
AFFCODE_POLYMARKET=AFFCODE_PLACEHOLDER_polymarket
AFFCODE_BET365=AFFCODE_PLACEHOLDER_bet365
AFFCODE_SKY_NZ=AFFCODE_PLACEHOLDER_sky_nz
AFFCODE_ESPN_PLUS=AFFCODE_PLACEHOLDER_espn_plus
AFFCODE_DAZN=AFFCODE_PLACEHOLDER_dazn

# --- logging ---
LOG_LEVEL=info
# LOG_PRETTY=1

# --- env ---
# Setting NODE_ENV=production triggers strict checks (e.g. requires
# AFFILIATE_USER_HASH_SALT to be a real value).
# NODE_ENV=production
