# Tournament bot — environment template. Never commit a populated .env.

# BotFather token. Get one by messaging @BotFather on Telegram, /newbot, follow prompts.
TELEGRAM_BOT_TOKEN=000000000:replace-me-with-real-token

# Public webhook base URL. Cloudflare-fronted, must be HTTPS.
PUBLIC_WEBHOOK_BASE=https://bot.tournamental.com

# Telegram-supplied secret token; bot rejects updates whose
# X-Telegram-Bot-Api-Secret-Token header doesn't match.
TELEGRAM_WEBHOOK_SECRET=replace-me-with-32-random-chars

# Internal HTTP port (Cloudflare tunnel maps bot.tournamental.com → here).
PORT=3350

# SQLite path. .gitignored.
TG_DB_PATH=./tg.db

# Comma-separated ISO country codes for which Polymarket affiliate CTAs are blocked.
# Per docs/30 + docs/18 — NZ + AU illegal, FR/UK conditional.
AFFILIATE_BLOCKED_COUNTRIES=NZ,AU

# Default user timezone when we don't have one yet.
DEFAULT_USER_TZ=Pacific/Auckland

# Log level for pino (silent | error | warn | info | debug | trace).
LOG_LEVEL=info

# ---- WhatsApp via the Aiva gateway (optional) ------------------------------
#
# The Aiva SMS gateway runs a Baileys session under the hood; once paired in
# the gateway admin UI it delivers inbound WA messages to our webhook below
# and accepts outbound HTTP `send` calls. Set all four to enable; leave any
# blank to disable WA (Telegram keeps working regardless).

# Base URL of the Aiva gateway (defaults to localhost:9252).
AIVA_SMS_API_URL=http://localhost:9252

# Bearer token issued by the Aiva admin dashboard.
AIVA_SMS_API_KEY=

# Session ID configured in the Aiva admin dashboard for this bot.
AIVA_WA_SESSION_ID=

# Shared secret the Aiva gateway uses to HMAC-sign inbound webhooks.
# Generate with: openssl rand -hex 32
AIVA_WEBHOOK_SECRET=
