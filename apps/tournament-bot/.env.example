# Tournament bot — environment template. Never commit a populated .env.

# BotFather token. Get one by messaging @BotFather on Telegram, /newbot, follow prompts.
TELEGRAM_BOT_TOKEN=000000000:replace-me-with-real-token

# Public webhook base URL. Cloudflare-fronted, must be HTTPS.
PUBLIC_WEBHOOK_BASE=https://bot.vtourn.com

# Telegram-supplied secret token; bot rejects updates whose
# X-Telegram-Bot-Api-Secret-Token header doesn't match.
TELEGRAM_WEBHOOK_SECRET=replace-me-with-32-random-chars

# Internal HTTP port (Cloudflare tunnel maps bot.vtourn.com → here).
PORT=3350

# SQLite path. .gitignored.
TG_DB_PATH=./tg.db

# Comma-separated ISO country codes for which Polymarket affiliate CTAs are blocked.
# Per docs/30 + docs/18 — NZ + AU illegal, FR/UK conditional.
AFFILIATE_BLOCKED_COUNTRIES=NZ,AU

# Default user timezone when we don't have one yet.
DEFAULT_USER_TZ=Pacific/Auckland

# Log level for pino (silent | error | warn | info | debug | trace).
LOG_LEVEL=info
