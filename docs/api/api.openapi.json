{
  "openapi": "3.0.0",
  "info": {
    "title": "VTorn API",
    "description": "Public VTorn API surface. Health, version, and aggregate endpoints. See docs/03-architecture.md for the full system topology.",
    "version": "0.0.1",
    "license": {
      "name": "Apache-2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0"
    }
  },
  "components": {
    "schemas": {}
  },
  "paths": {
    "/": {
      "get": {
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Liveness probe",
        "tags": [
          "health"
        ],
        "description": "Always returns 200 with the current server timestamp. Cache-Control: no-store.",
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status",
                    "ts"
                  ],
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "ok"
                      ]
                    },
                    "ts": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/version": {
      "get": {
        "summary": "Service version",
        "tags": [
          "health"
        ],
        "description": "Identifies the running service, package version, spec version, and environment. Cached for 60s.",
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "service",
                    "version",
                    "spec_version",
                    "env",
                    "ts"
                  ],
                  "properties": {
                    "service": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    },
                    "spec_version": {
                      "type": "string"
                    },
                    "env": {
                      "type": "string"
                    },
                    "ts": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "http://localhost:3310",
      "description": "local dev"
    },
    {
      "url": "https://api.tournamental.com",
      "description": "production"
    }
  ],
  "tags": [
    {
      "name": "health",
      "description": "Liveness + version"
    },
    {
      "name": "social-cards",
      "description": "OG card rendering"
    },
    {
      "name": "admin",
      "description": "Operator-only endpoints"
    }
  ]
}
