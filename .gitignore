# Large generated stream dumps live under apps/web/public/data/arfr-stream/.
# These are produced by `apps/statsbomb-replay` and should not be committed.
# Test fixtures (prefixed __fixture__) ARE checked in.
apps/web/public/data/arfr-stream/*.ndjson
apps/web/public/data/arfr-stream/*.ndjson.gz
!apps/web/public/data/arfr-stream/__fixture__.ndjson

# Playwright local artefacts (HTML reporter output + per-run results).
# The visual-snapshot fixtures under test-fixtures/visual/ ARE committed
# so PR reviewers can inspect them.

# Pre-launch syndicate signups are PII (email, name, optional Telegram).
# /api/syndicate/intent writes to data/pre-signups/<id>.json. Never commit.
data/pre-signups/*.json
!data/pre-signups/README.md

# Playwright outputs (e2e screenshots + test results + html report).
apps/web/.playwright-screenshots/
apps/web/test-results/
apps/web/playwright-report/

# Auth service runtime state (PII + WhatsApp credentials — never commit).
apps/auth-sms/data/
apps/auth-sms/baileys-auth/
apps/auth-sms/auth.db
apps/auth-sms/auth.db-journal
apps/auth-sms/auth.db-wal
apps/auth-sms/auth.db-shm

# Local screenshot output (demo only).
.screenshots/
