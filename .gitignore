node_modules/
.next/
dist/
.env
.env.local
*.log
.DS_Store
__pycache__/
.venv/
.uv/
*.pyc
*.tsbuildinfo

# Large generated stream dumps live under apps/web/public/data/arfr-stream/.
# These are produced by `apps/statsbomb-replay` and should not be committed.
# Test fixtures (prefixed __fixture__) ARE checked in.
apps/web/public/data/arfr-stream/*.ndjson
apps/web/public/data/arfr-stream/*.ndjson.gz
!apps/web/public/data/arfr-stream/__fixture__.ndjson

# Playwright local artefacts (HTML reporter output + per-run results).
# The visual-snapshot fixtures under test-fixtures/visual/ ARE committed
# so PR reviewers can inspect them.

# Pre-launch syndicate signups are PII (email, name, optional Telegram).
# /api/syndicate/intent writes to data/pre-signups/<id>.json. Never commit.
data/pre-signups/*.json
!data/pre-signups/README.md

# Playwright outputs (e2e screenshots + test results + html report).
apps/web/.playwright-screenshots/
apps/web/test-results/
apps/web/playwright-report/
apps/marketing/e2e-screenshots/
apps/marketing/test-results/
apps/marketing/playwright-report/

# Auth service runtime state (PII + WhatsApp credentials — never commit).
apps/auth-sms/data/
apps/auth-sms/baileys-auth/
apps/auth-sms/auth.db
apps/auth-sms/auth.db-journal
apps/auth-sms/auth.db-wal
apps/auth-sms/auth.db-shm

# Local screenshot output (demo only).
.screenshots/

# Runtime OG image caches — regenerated on demand by /api/og/bracket and
# /api/og/syndicate. Keyed by content-addressed ids, so committing them
# would just bloat the repo.
apps/web/public/og/bracket/
apps/web/public/og/syndicate/

# API docs portal bundle + per-service slices, regenerated at marketing
# build time by `scripts/build-openapi-index.mjs`. The source of truth
# is `docs/api/<service>.openapi.json`; this folder is a build artefact.
# Exception: manifest.json IS committed so `astro check` (typecheck) can
# import it without a build step running first.
apps/marketing/public/api/*
!apps/marketing/public/api/manifest.json

# Deploy slots — built artefacts, never committed. The .deploy/config.json
# files ARE committed (per-app deploy config); .deploy/rollback.json and
# incident.flag are runtime-only.
apps/*/.next-staging/
apps/*/.next-prod/
apps/*/.next-prev/
apps/*/.next-failed/
apps/*/dist-staging/
apps/*/dist-prod/
apps/*/dist-prev/
apps/*/dist-failed/
apps/*/.deploy/rollback.json
apps/*/.env.staging
apps/*/.env.production
.deploy/incident.flag

# Deploy timings JSONL is host-local; not committed.
data/deploy-timings.jsonl

# Per-team Wikidata SPARQL response cache. Regenerated by the
# `scrape-players` CLI; not part of the build artefact and not committed.
apps/wc2026-data/data/players-cache/

# Per-key stats scraper cache (form / h2h / stats). Regenerated by the
# `scrape-stats` CLI; not committed.
apps/wc2026-data/data/stats-cache/

# Agent worktree pollution from local runs (gitignored to prevent embedded-repo warnings).
.claude/worktrees/
projects-fix-share-page-cascade-and-molecule/
.playwright-mcp/
qa-launch-screenshots/
.playwright-mcp/

# User-uploaded avatars — filesystem-backed (Tim 2026-05-14).
# Avatars are deterministic per user (`<userId>.jpg`) so anything in
# this dir is per-installation, not source-controlled content.
apps/web/public/avatars/*
!apps/web/public/avatars/.gitkeep
apps/*/.next-dev/
apps/*/.next-dev-test/

# Local agent-runtime state (lock files etc) outside the worktrees subtree.
.claude/scheduled_tasks.lock
apps/*/.next-typecheck/
.admin-audit.jsonl

# --- Internal-only artefacts (do not commit) ----------------------------------
# Tim 2026-06-01: marketing playbooks, outreach lists with prospect emails,
# and HighLevel campaign setup state must stay off git. They live on disk at
# docs/internal/* and sync to Drive (parent 1bQg04rzrYXtx3QMocASP1dVnmSqtK1rH).
# See docs/internal/README.md for the policy.
docs/internal/

# Also block historical paths these files used to live at, in case someone
# accidentally recreates them. Move new ones to docs/internal/<path> instead.
tools/outreach-lists/
data/hl-setup/
data/form-drafts/
data/form-screenshots/

# Audit snapshot binaries — written by infra/audit/anchor.sh. The
# ledger.json IS committed (the append-only hash chain is the audit
# value); the binary snapshot.db + snapshot.db.ots files are served
# from disk by /verify/[ts]/[file]/route.ts. Tim 2026-06-04.
apps/web/data/audit/*/snapshot.db
apps/web/data/audit/*/snapshot.db.ots

# billion-bot: packed npm tarballs + runtime data are build/runtime artifacts
apps/billion-bot/*.tgz
apps/billion-bot/data/
apps/game/data-dev/
